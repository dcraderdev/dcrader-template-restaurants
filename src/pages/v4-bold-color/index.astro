---
import Layout from '../../layouts/Layout.astro';
import { restaurant } from '../../data/restaurants/v4';

const fontUrl = 'https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Source+Sans+3:wght@300;400;600&display=swap';

const firstCategory = restaurant.menu.categories[0];
---

<Layout
  restaurant={restaurant}
  theme="v4"
  fontUrl={fontUrl}
>

  <!-- ============================================================
       STYLES
  ============================================================ -->
  <style>
    /* ---- CSS Custom Properties ---- */
    :root {
      --v4-terra: #D64A1A;
      --v4-terra-dark: #B23A10;
      --v4-yellow: #F5C842;
      --v4-teal: #0A6B6B;
      --v4-white: #FFFFFF;
      --v4-dark: #180A00;
      --v4-black: #0D0500;
      --v4-muted: #6B5A48;
      --v4-border: rgba(24,10,0,0.12);
    }

    /* Scroll-reveal disabled: content visible immediately. */
    .sr, .sr-visible {
      opacity: 1;
      transform: none;
      transition: none;
    }

    /* ---- Base typography reset ---- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Source Sans 3', sans-serif; background: var(--v4-white); color: var(--v4-dark); }
    h1, h2, h3, h4, h5, h6, .v4-oswald { font-family: 'Oswald', sans-serif; }
    a { text-decoration: none; color: inherit; }

    /* ============================================================
       NAV
    ============================================================ */
    .v4-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      height: 4rem;
      background: var(--v4-terra);
      display: flex;
      align-items: center;
      padding: 0 2rem;
    }

    .v4-nav-logo {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 1.4rem;
      letter-spacing: 0.12em;
      color: var(--v4-white);
      text-transform: uppercase;
      flex-shrink: 0;
    }

    .v4-nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
      flex: 1;
      justify-content: center;
      list-style: none;
    }

    .v4-nav-links a {
      font-family: 'Oswald', sans-serif;
      font-weight: 400;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.85);
      transition: color 0.2s;
    }
    .v4-nav-links a:hover { color: var(--v4-yellow); }

    .v4-nav-reserve {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--v4-white);
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
      flex-shrink: 0;
    }
    .v4-nav-reserve:hover { border-color: var(--v4-white); }

    .v4-nav-hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;
      flex-direction: column;
      gap: 5px;
    }
    .v4-nav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--v4-white);
      border-radius: 1px;
      transition: transform 0.25s, opacity 0.25s;
    }
    .v4-nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .v4-nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .v4-nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .v4-mobile-menu {
      display: none;
      position: fixed;
      top: 4rem;
      left: 0;
      right: 0;
      z-index: 999;
      background: var(--v4-teal);
      padding: 2rem;
      transform: translateY(-100%);
      transition: transform 0.3s ease;
    }
    .v4-mobile-menu.open { transform: translateY(0); }
    .v4-mobile-menu ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .v4-mobile-menu a {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 1.1rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--v4-white);
    }

    /* ============================================================
       HERO
    ============================================================ */
    .v4-hero {
      min-height: 100vh;
      display: flex;
      flex-direction: row;
      padding-top: 4rem;
    }

    /* Left Panel */
    .v4-hero-left {
      width: 48%;
      background: var(--v4-dark);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 4rem 0 5rem;
      position: relative;
      overflow: hidden;
    }

    .v4-hero-yellow-stripe {
      width: 4rem;
      height: 6px;
      background: var(--v4-yellow);
      margin-bottom: 1.5rem;
    }

    .v4-hero-eyebrow {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      margin-bottom: 1.25rem;
    }

    .v4-hero-h1 {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: clamp(4.5rem, 8vw, 9rem);
      line-height: 0.85;
      text-transform: uppercase;
      color: var(--v4-white);
      letter-spacing: -0.01em;
    }

    .v4-hero-rule {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.2);
      margin: 1.5rem 0;
    }

    .v4-hero-subtitle {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      color: rgba(255,255,255,0.7);
      max-width: 26rem;
      line-height: 1.65;
      margin-bottom: 2.5rem;
    }

    .v4-hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .v4-btn-yellow {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      background: var(--v4-yellow);
      color: var(--v4-dark);
      padding: 0.85rem 2rem;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      display: inline-block;
    }
    .v4-btn-yellow:hover { background: #e0b430; transform: translateY(-1px); }

    .v4-btn-outline-white {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      background: transparent;
      color: var(--v4-white);
      padding: 0.85rem 2rem;
      border: 1.5px solid var(--v4-white);
      cursor: pointer;
      transition: background 0.2s, color 0.2s, transform 0.15s;
      display: inline-block;
    }
    .v4-btn-outline-white:hover {
      background: var(--v4-white);
      color: var(--v4-dark);
      transform: translateY(-1px);
    }

    /* Right Panel */
    .v4-hero-right {
      width: 52%;
      position: relative;
      overflow: hidden;
    }

    .v4-hero-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(1.15) contrast(1.05);
    }

    .v4-hero-img-frame {
      position: absolute;
      inset: 0;
      outline: 4px solid var(--v4-white);
      outline-offset: -12px;
      pointer-events: none;
      z-index: 2;
    }

    .v4-hero-teal-overlay {
      position: absolute;
      inset: 0;
      background: rgba(10,107,107,0.08);
      pointer-events: none;
      z-index: 1;
    }

    /* Hero entrance animation */
    .v4-hero-left { animation: v4HeroLeft 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    .v4-hero-right { animation: v4HeroRight 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }

    @keyframes v4HeroLeft {
      from { opacity: 0; transform: translateX(-30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes v4HeroRight {
      from { opacity: 0; transform: translateX(30px); }
      to { opacity: 1; transform: translateX(0); }
    }

    /* ============================================================
       YELLOW TAGLINE BAR
    ============================================================ */
    .v4-tagline-bar {
      background: var(--v4-yellow);
      padding: 1.1rem 2rem;
      text-align: center;
    }
    .v4-tagline-bar-text {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--v4-dark);
    }

    /* ============================================================
       MENU
    ============================================================ */
    .v4-menu-section {
      background: var(--v4-white);
      padding: 7rem 0;
    }

    .v4-menu-inner {
      display: flex;
      flex-direction: row;
      max-width: 1280px;
      margin: 0 auto;
      min-height: 540px;
    }

    /* Sidebar */
    .v4-menu-sidebar {
      width: 240px;
      flex-shrink: 0;
      background: var(--v4-teal);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 4rem;
      align-self: flex-start;
      min-height: 400px;
    }

    .v4-menu-tab-btn {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
      background: transparent;
      border: none;
      padding: 1.1rem 1.5rem;
      text-align: left;
      cursor: pointer;
      border-left: 3px solid transparent;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      width: 100%;
    }
    .v4-menu-tab-btn:hover { color: var(--v4-white); background: rgba(255,255,255,0.07); }
    .v4-menu-tab-btn.active {
      background: var(--v4-terra);
      color: var(--v4-white);
      border-left-color: var(--v4-yellow);
    }

    /* Menu content */
    .v4-menu-content {
      flex: 1;
      padding: 0 3rem 0 3.5rem;
    }

    .v4-menu-header {
      margin-bottom: 2rem;
    }

    .v4-menu-title {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 3rem;
      text-transform: uppercase;
      color: var(--v4-dark);
      line-height: 1;
      margin-bottom: 0.75rem;
    }

    .v4-menu-note {
      font-family: 'Source Sans 3', sans-serif;
      font-style: italic;
      font-size: 0.9rem;
      color: var(--v4-muted);
      line-height: 1.55;
      max-width: 36rem;
    }

    /* Category panel */
    .v4-menu-panel { display: none; }
    .v4-menu-panel.active { display: block; }

    .v4-menu-category-heading {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 1.5rem;
      text-transform: uppercase;
      color: var(--v4-terra);
      letter-spacing: 0.05em;
      margin-bottom: 2rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--v4-yellow);
    }

    .v4-menu-items { list-style: none; display: flex; flex-direction: column; gap: 0; }

    .v4-menu-item {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
      padding: 1.1rem 0;
      border-bottom: 1px solid var(--v4-border);
    }

    .v4-menu-item-body { flex: 1; }

    .v4-menu-item-name {
      font-family: 'Oswald', sans-serif;
      font-weight: 500;
      font-size: 1.1rem;
      color: var(--v4-dark);
      display: block;
      margin-bottom: 0.25rem;
    }

    .v4-menu-item-desc {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.82rem;
      color: var(--v4-muted);
      line-height: 1.5;
    }

    .v4-menu-item-price {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 1rem;
      color: var(--v4-terra);
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* ============================================================
       GALLERY (bento grid)
    ============================================================ */
    .v4-gallery-section {
      background: var(--v4-dark);
      padding: 7rem 2.5rem;
    }

    .v4-gallery-heading {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 4rem;
      text-transform: uppercase;
      color: var(--v4-white);
      letter-spacing: 0.04em;
      margin-bottom: 3rem;
    }

    .v4-gallery-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 220px;
      gap: 10px;
      max-width: 1280px;
      margin: 0 auto;
    }

    .v4-gallery-cell {
      overflow: hidden;
      position: relative;
    }
    .v4-gallery-cell img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(1.1) contrast(1.05);
      transition: transform 0.5s ease, filter 0.5s ease;
    }
    .v4-gallery-cell:hover img {
      transform: scale(1.04);
      filter: saturate(1.25) contrast(1.08);
    }

    .v4-gallery-cell.span-col-2 { grid-column: span 2; }
    .v4-gallery-cell.span-row-2 { grid-row: span 2; }
    .v4-gallery-cell.span-both { grid-column: span 2; grid-row: span 2; }

    .v4-gallery-color-terra {
      background: var(--v4-terra);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .v4-gallery-color-terra-text {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--v4-white);
      writing-mode: vertical-rl;
      text-orientation: mixed;
      transform: rotate(180deg);
    }

    .v4-gallery-color-yellow {
      background: var(--v4-yellow);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .v4-gallery-color-yellow-text {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--v4-dark);
    }

    /* ============================================================
       ABOUT
    ============================================================ */
    .v4-about-section {
      background: var(--v4-terra);
      padding: 7rem 2.5rem;
    }

    .v4-about-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .v4-about-label {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--v4-yellow);
      display: block;
      margin-bottom: 1rem;
    }

    .v4-about-h2 {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: clamp(2.5rem, 4vw, 4rem);
      text-transform: uppercase;
      color: var(--v4-white);
      line-height: 0.92;
      margin-bottom: 2rem;
    }

    .v4-about-story {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.85);
      line-height: 1.75;
      margin-bottom: 1.25rem;
    }

    .v4-about-chef-rule {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.25);
      margin: 2rem 0;
    }

    .v4-about-chef-name {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 1.5rem;
      color: var(--v4-white);
      display: block;
      margin-bottom: 0.25rem;
    }

    .v4-about-chef-title {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.8rem;
      color: var(--v4-yellow);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.75rem;
    }

    .v4-about-chef-bio {
      font-family: 'Source Sans 3', sans-serif;
      font-style: italic;
      font-size: 0.9rem;
      color: rgba(255,255,255,0.75);
      line-height: 1.6;
    }

    /* Right column — chef photo */
    .v4-about-photo-col {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .v4-about-photo-wrap {
      position: relative;
      display: inline-block;
    }

    .v4-about-chef-photo {
      width: 320px;
      height: 320px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      border: 4px solid var(--v4-yellow);
    }

    .v4-about-photo-accent {
      position: absolute;
      bottom: -12px;
      right: -12px;
      width: 100px;
      height: 100px;
      background: var(--v4-yellow);
      border-radius: 50%;
      z-index: -1;
    }

    /* ============================================================
       RESERVATIONS
    ============================================================ */
    .v4-reservations-section {
      background: var(--v4-dark);
      padding: 7rem 2.5rem;
    }

    .v4-reservations-inner {
      max-width: 44rem;
      margin: 0 auto;
      text-align: center;
    }

    .v4-reservations-heading {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: clamp(2.5rem, 5vw, 4rem);
      text-transform: uppercase;
      color: var(--v4-white);
      line-height: 0.92;
      margin-bottom: 1rem;
    }

    .v4-reservations-heading em {
      color: var(--v4-yellow);
      font-style: normal;
    }

    .v4-reservations-subtitle {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      margin-bottom: 3rem;
      line-height: 1.55;
    }

    .v4-res-form {
      text-align: left;
    }

    .v4-res-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .v4-res-field { display: flex; flex-direction: column; gap: 0.4rem; }
    .v4-res-field.full { grid-column: 1 / -1; }

    .v4-res-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }

    .v4-res-input,
    .v4-res-select,
    .v4-res-textarea {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      color: var(--v4-white);
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 0.85rem 1rem;
      outline: none;
      width: 100%;
      transition: border-color 0.2s;
      border-radius: 2px;
    }
    .v4-res-input::placeholder,
    .v4-res-textarea::placeholder { color: rgba(255,255,255,0.3); }
    .v4-res-input:focus,
    .v4-res-select:focus,
    .v4-res-textarea:focus { border-color: var(--v4-yellow); }
    .v4-res-select option { background: var(--v4-dark); color: var(--v4-white); }
    .v4-res-textarea { resize: vertical; min-height: 90px; }

    .v4-res-submit {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--v4-dark);
      background: var(--v4-yellow);
      border: none;
      padding: 1.1rem 2rem;
      cursor: pointer;
      width: 100%;
      margin-top: 1.25rem;
      transition: background 0.2s, transform 0.15s;
    }
    .v4-res-submit:hover { background: #e0b430; transform: translateY(-1px); }

    .v4-res-phone {
      margin-top: 2rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.9rem;
      color: rgba(255,255,255,0.5);
    }
    .v4-res-phone a {
      color: var(--v4-yellow);
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
    }

    /* ============================================================
       CONTACT
    ============================================================ */
    .v4-contact-section {
      background: var(--v4-white);
      padding: 7rem 2.5rem;
    }

    .v4-contact-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .v4-contact-heading {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: clamp(2rem, 3.5vw, 3rem);
      text-transform: uppercase;
      color: var(--v4-dark);
      margin-bottom: 2.5rem;
      line-height: 0.95;
    }

    .v4-contact-block { margin-bottom: 2rem; }

    .v4-contact-block-label {
      font-family: 'Oswald', sans-serif;
      font-weight: 600;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--v4-terra);
      display: block;
      margin-bottom: 0.5rem;
    }

    .v4-contact-block-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      color: var(--v4-dark);
      line-height: 1.7;
    }
    .v4-contact-block-text a { color: var(--v4-terra); }
    .v4-contact-block-text a:hover { text-decoration: underline; }

    .v4-hours-table { width: 100%; border-collapse: collapse; }
    .v4-hours-table tr { border-bottom: 1px solid var(--v4-border); }
    .v4-hours-table td {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.9rem;
      padding: 0.5rem 0;
      color: var(--v4-dark);
    }
    .v4-hours-table td:first-child { font-weight: 600; width: 45%; }
