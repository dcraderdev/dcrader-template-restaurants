---
import Layout from '../../layouts/Layout.astro';
import { restaurant } from '../../data/restaurants/v5';

const FONT_URL =
  'https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap';
---

<Layout
  restaurant={restaurant}
  theme="v5"
  fontUrl={FONT_URL}
>

<!-- ===================== STYLES ===================== -->
<style>
  /* ---- CSS Variables ---- */
  :root {
    --v5-black:       #0B0A08;
    --v5-surface:     #141210;
    --v5-surface-2:   #1C1916;
    --v5-gold:        #C9A84C;
    --v5-gold-light:  #E5C97A;
    --v5-copper:      #B87333;
    --v5-white:       #EDE8DE;
    --v5-muted:       #6A6258;
    --v5-border:      rgba(237,232,222,0.08);
    --v5-border-gold: rgba(201,168,76,0.25);
  }

  /* ---- Reset / base ---- */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--v5-black); color: var(--v5-white); font-family: 'Montserrat', sans-serif; -webkit-font-smoothing: antialiased; }

  /* Scroll-reveal disabled: content visible immediately. */
  .sr, .sr-visible { opacity: 1; transform: none; transition: none; }

  /* =============================================
     NAV
  ============================================= */
  .v5-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.75rem 2.5rem;
    transition: background 0.4s ease, border-color 0.4s ease, padding 0.4s ease;
    border-top: 1px solid transparent;
  }
  .v5-nav.scrolled {
    background: rgba(11,10,8,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top-color: rgba(201,168,76,0.3);
    padding: 1.1rem 2.5rem;
  }

  /* Monogram */
  .v5-nav__monogram {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.8rem;
    color: var(--v5-gold);
    line-height: 1;
    text-decoration: none;
    letter-spacing: 0;
  }

  /* Desktop links */
  .v5-nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    list-style: none;
  }
  .v5-nav__links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.58rem;
    font-weight: 300;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--v5-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .v5-nav__links a:hover { color: var(--v5-white); }
  .v5-nav__links a.reserve { color: var(--v5-gold); }
  .v5-nav__links a.reserve:hover { color: var(--v5-gold-light); }

  /* Hamburger */
  .v5-nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  .v5-nav__burger span {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--v5-gold);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .v5-nav__burger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .v5-nav__burger.open span:nth-child(2) { opacity: 0; }
  .v5-nav__burger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* Mobile overlay */
  .v5-nav__overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--v5-black);
    z-index: 190;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3rem;
  }
  .v5-nav__overlay.open { display: flex; }
  .v5-nav__overlay a {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--v5-white);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }
  .v5-nav__overlay a:hover { color: var(--v5-gold); }
  .v5-nav__overlay a.reserve { color: var(--v5-gold); }

  /* =============================================
     STICKY BOTTOM CTA BAR
  ============================================= */
  .v5-sticky-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 100;
    height: 3rem;
    background: var(--v5-gold);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    transform: translateY(100%);
    transition: transform 0.4s ease;
    pointer-events: none;
  }
  .v5-sticky-bar.visible {
    transform: translateY(0);
    pointer-events: auto;
  }
  .v5-sticky-bar__label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(11,10,8,0.7);
  }
  .v5-sticky-bar__cta {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--v5-black);
    text-decoration: none;
    padding: 0 2rem;
    transition: opacity 0.2s ease;
  }
  .v5-sticky-bar__cta:hover { opacity: 0.75; }

  /* =============================================
     HERO
  ============================================= */
  .v5-hero {
    min-height: 100vh;
    background: var(--v5-black);
    display: flex;
    flex-direction: column;
  }

  /* Top text section */
  .v5-hero__top {
    min-height: 55vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
    gap: 1.8rem;
  }

  /* Eyebrow rule */
  .v5-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 28rem;
  }
  .v5-hero__eyebrow-line {
    flex: 1;
    height: 1px;
    background: var(--v5-gold);
    opacity: 0.4;
  }
  .v5-hero__eyebrow-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--v5-gold);
    white-space: nowrap;
  }

  /* H1 */
  .v5-hero__h1 {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(4rem, 9vw, 8.5rem);
    line-height: 0.92;
    color: var(--v5-white);
    letter-spacing: -0.01em;
  }

  /* Ornament (line · dot · line) */
  .v5-hero__ornament {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .v5-hero__ornament-line {
    width: 2.5rem;
    height: 1px;
    background: var(--v5-gold);
    opacity: 0.5;
  }
  .v5-hero__ornament-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--v5-gold);
    opacity: 0.7;
  }

  /* Subtitle */
  .v5-hero__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--v5-muted);
    max-width: 32rem;
  }

  /* CTA link */
  .v5-hero__cta {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--v5-gold);
    text-decoration: none;
    border-bottom: 1px solid var(--v5-gold);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .v5-hero__cta:hover {
    color: var(--v5-gold-light);
    border-color: var(--v5-gold-light);
  }

  /* Bottom image section */
  .v5-hero__image-wrap {
    flex: 1;
    min-height: 45vh;
    position: relative;
    overflow: hidden;
  }
  .v5-hero__image-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to bottom, rgba(11,10,8,0.6) 0%, transparent 100%);
    z-index: 1;
  }
  .v5-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85) contrast(1.08) saturate(0.9);
  }

  /* Hero entrance animation */
  .v5-hero__top { animation: heroFadeUp 1.2s ease both; }
  .v5-hero__top .v5-hero__eyebrow { animation: heroFadeUp 1.2s 0.1s ease both; }
  .v5-hero__top .v5-hero__h1   { animation: heroFadeUp 1.2s 0.25s ease both; }
  .v5-hero__top .v5-hero__ornament { animation: heroFadeUp 1.2s 0.4s ease both; }
  .v5-hero__top .v5-hero__subtitle { animation: heroFadeUp 1.2s 0.5s ease both; }
  .v5-hero__top .v5-hero__cta  { animation: heroFadeUp 1.2s 0.65s ease both; }
  .v5-hero__image-wrap { animation: heroReveal 1.6s 0.4s ease both; }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroReveal {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* =============================================
     SECTION COMMONS
  ============================================= */
  .v5-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--v5-gold);
    display: block;
    margin-bottom: 0.75rem;
  }
  .v5-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--v5-white);
    line-height: 1.1;
  }

  /* =============================================
     MENU
  ============================================= */
  .v5-menu {
    background: var(--v5-black);
    padding: 8rem 2.5rem;
  }
  .v5-menu__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .v5-menu__header .v5-section-title { margin-top: 0.5rem; }

  /* Tabs */
  .v5-menu__tabs {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }
  .v5-menu__tab {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--v5-border-gold);
    background: transparent;
    color: var(--v5-gold);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .v5-menu__tab:hover { background: rgba(201,168,76,0.1); }
  .v5-menu__tab.active {
    background: var(--v5-gold);
    color: var(--v5-black);
    border-color: var(--v5-gold);
  }

  /* Panels */
  .v5-menu__panel { display: none; max-width: 52rem; margin: 0 auto; }
  .v5-menu__panel.active { display: block; }

  /* Item */
  .v5-menu__item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(237,232,222,0.06);
  }
  .v5-menu__item-body { flex: 1; }
  .v5-menu__item-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--v5-white);
    display: block;
    margin-bottom: 0.2rem;
  }
  .v5-menu__item-desc {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.78rem;
    color: var(--v5-muted);
    line-height: 1.65;
  }
  .v5-menu__item-price {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--v5-gold);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Note */
  .v5-menu__note {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-style: italic;
    font-size: 0.72rem;
    color: var(--v5-muted);
    text-align: center;
    max-width: 52rem;
    margin: 2.5rem auto 0;
    line-height: 1.65;
  }

  /* =============================================
     GALLERY
  ============================================= */
  .v5-gallery {
    background: var(--v5-surface);
    padding: 8rem 2.5rem;
  }
  .v5-gallery__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .v5-gallery__header .v5-section-title { margin-top: 0.5rem; }
  .v5-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 72rem;
    margin: 0 auto;
  }
  .v5-gallery__item {
    overflow: hidden;
    cursor: pointer;
  }
  .v5-gallery__item:nth-child(1) { aspect-ratio: 4/5; }
  .v5-gallery__item:nth-child(2) { aspect-ratio: 4/3; }
  .v5-gallery__item:nth-child(3) { aspect-ratio: 3/4; }
  .v5-gallery__item:nth-child(4) { aspect-ratio: 16/9; grid-column: span 2; }
  .v5-gallery__item:nth-child(5) { aspect-ratio: 4/3; }
  .v5-gallery__item:nth-child(6) { aspect-ratio: 2/3; }
  .v5-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.88) contrast(1.1) saturate(0.85);
    transition: filter 0.4s ease, box-shadow 0.4s ease;
  }
  .v5-gallery__item:hover .v5-gallery__img {
    filter: brightness(0.95) contrast(1.05) saturate(1.0);
    box-shadow: 0 0 0 1px var(--v5-gold);
  }

  /* =============================================
     ABOUT
  ============================================= */
  .v5-about {
    background: var(--v5-black);
    padding: 8rem 2.5rem;
  }
  .v5-about__inner {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: 5rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: start;
  }
  .v5-about__label { margin-bottom: 1.2rem; }
  .v5-about__h2 {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    color: var(--v5-white);
    line-height: 1.1;
    margin-bottom: 1.8rem;
  }
  .v5-about__rule {
    width: 3rem;
    height: 1px;
    background: var(--v5-gold);
    margin-bottom: 1.8rem;
  }
  .v5-about__story {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: var(--v5-muted);
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }
  /* Chef card */
  .v5-about__chef {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--v5-border);
  }
  .v5-about__chef-name {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.4rem;
    color: var(--v5-gold);
    display: block;
    margin-bottom: 0.3rem;
  }
  .v5-about__chef-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--v5-muted);
    display: block;
    margin-bottom: 0.8rem;
  }
  .v5-about__chef-bio {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    color: var(--v5-muted);
    line-height: 1.7;
  }
  /* Right photo */
  .v5-about__photo-wrap {
    position: sticky;
    top: 6rem;
    border-right: 1px solid rgba(201,168,76,0.3);
    overflow: hidden;
  }
  .v5-about__photo {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    display: block;
    filter: brightness(0.85) contrast(1.1) grayscale(0.2);
  }

  /* =============================================
     RESERVATIONS
  ============================================= */
  .v5-reserve {
    background: var(--v5-surface-2);
    padding: 8rem 2.5rem;
  }
  .v5-reserve__inner {
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }
  .v5-reserve__label { margin-bottom: 0.75rem; }
  .v5-reserve__h2 {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    color: var(--v5-white);
    margin-bottom: 1rem;
  }
  .v5-reserve__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: var(--v5-muted);
    line-height: 1.7;
    margin-bottom: 3rem;
  }
  /* Form */
  .v5-reserve__form {
    text-align: left;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
  }
  .v5-reserve__form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .v5-reserve__form-group.full { grid-column: span 2; }
  .v5-reserve__label-el {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--v5-muted);
  }
  .v5-reserve__input,
  .v5-reserve__select,
  .v5-reserve__textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--v5-border);
    color: var(--v5-white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 300;
    padding: 0.65rem 0;
    width: 100%;
    outline: none;
    transition: border-color 0.2s ease;
    -webkit-appearance: none;
  }
  .v5-reserve__select option { background: var(--v5-surface-2); color: var(--v5-white); }
  .v5-reserve__input::placeholder,
  .v5-reserve__textarea::placeholder { color: var(--v5-muted); }
  .v5-reserve__input:focus,
  .v5-reserve__select:focus,
  .v5-reserve__textarea:focus { border-bottom-color: var(--v5-gold); }
  .v5-reserve__textarea { resize: vertical; min-height: 80px; }
  .v5-reserve__submit {
    grid-column: span 2;
    background: var(--v5-gold);
    color: var(--v5-black);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    border: none;
    padding: 1.1rem;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s ease, opacity 0.2s ease;
    margin-top: 0.5rem;
  }
  .v5-reserve__submit:hover { opacity: 0.85; }
  .v5-reserve__phone {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--v5-gold);
    display: block;
    margin-top: 2rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .v5-reserve__phone:hover { color: var(--v5-gold-light); }

  /* =============================================
     CONTACT
  ============================================= */
  .v5-contact {
    background: var(--v5-black);
    padding: 7rem 2.5rem;
  }
  .v5-contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: start;
  }
  .v5-contact__info-label { margin-bottom: 2rem; }
  .v5-contact__block { margin-bottom: 2.5rem; }
  .v5-contact__block-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--v5-gold);
    display: block;
    margin-bottom: 0.75rem;
  }
  .v5-contact__block p,
  .v5-contact__block a {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.88rem;
    color: var(--v5-muted);
    line-height: 1.7;
    text-decoration: none;
    display: block;
    transition: color 0.2s ease;
  }
  .v5-contact__block a:hover { color: var(--v5-white); }
  /* Hours table */
  .v5-hours {
    width: 100%;
    border-collapse: collapse;
  }
  .v5-hours tr {
    border-bottom: 1px solid var(--v5-border);
  }
  .v5-hours td {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    padding: 0.55rem 0;
    color: var(--v5-white);
  }
  .v5-hours td:last-child { text-align: right; color: var(--v5-muted); }
  .v5-hours tr.closed td { color: var(--v5-muted); }
  .v5-hours tr.closed td:last-child { color: var(--v5-muted); }
  /* Map */
  .v5-contact__map-wrap {
    position: sticky;
    top: 6rem;
  }
  .v5-contact__map {
    width: 100%;
    aspect-ratio: 4/3;
    border: none;
    display: block;
    filter: brightness(0.8) grayscale(0.4);
  }

  /* =============================================
     FOOTER
  ============================================= */
  .v5-footer {
    background: var(--v5-black);
    border-top: 1px solid var(--v5-border);
  }
  .v5-footer__rule {
    width: 100%;
    height: 1px;
    background: rgba(201,168,76,0.25);
  }
  .v5-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2.5rem 2.5rem;
  }
  .v5-footer__name {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--v5-gold);
  }
  .v5-footer__copy {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    font-weight: 300;
    color: var(--v5-muted);
    letter-spacing: 0.04em;
  }

  /* =============================================
     RESPONSIVE
  ============================================= */
  @media (max-width: 768px) {
    /* Nav */
    .v5-nav__links { display: none; }
    .v5-nav__burger { display: flex; }

    /* Hero */
    .v5-hero__top { padding: 7rem 1.5rem 3rem; }

    /* Sticky bar */
    .v5-sticky-bar { height: 2.5rem; }
    .v5-sticky-bar__label { display: none; }
    .v5-sticky-bar__cta { margin: 0 auto; }

    /* Menu */
    .v5-menu { padding: 5rem 1.5rem; }
    .v5-menu__tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .v5-menu__tabs::-webkit-scrollbar { display: none; }
    .v5-menu__tab { flex-shrink: 0; }

    /* Gallery */
    .v5-gallery { padding: 5rem 1.5rem; }
    .v5-gallery__grid {
      grid-template-columns: 1fr 1fr;
    }
    .v5-gallery__item:nth-child(4) { grid-column: span 2; }

    /* About */
    .v5-about { padding: 5rem 1.5rem; }
    .v5-about__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .v5-about__photo-wrap {
      position: static;
      order: -1;
      border-right: none;
      border-bottom: 1px solid rgba(201,168,76,0.3);
    }
    .v5-about__photo { aspect-ratio: 16/9; }

    /* Reservations */
    .v5-reserve { padding: 5rem 1.5rem; }
    .v5-reserve__form {
      grid-template-columns: 1fr;
    }
    .v5-reserve__form-group.full { grid-column: span 1; }
    .v5-reserve__submit { grid-column: span 1; }

    /* Contact */
    .v5-contact { padding: 5rem 1.5rem; }
    .v5-contact__inner { grid-template-columns: 1fr; gap: 3rem; }
    .v5-contact__map-wrap { position: static; }

    /* Footer */
    .v5-footer__inner {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>

