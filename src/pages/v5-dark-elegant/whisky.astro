---
import Layout from '../../layouts/Layout.astro';
import { restaurant } from '../../data/restaurants/v5';

const FONT_URL = 'https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap';
const pageTitle = `The Whisky Library — ${restaurant.name}`;

const sections = [
  {
    region: 'Japan',
    blurb: 'Our largest single category. We started building the Japanese collection in 2014 when Yamazaki 25 was still on the shelf at retail. Most of these can no longer be replaced.',
    items: [
      { name: 'Yamazaki 25', proof: '43%', age: '25 yr', pour: '$285 / oz', notes: 'Sherry-cask. Mizunara wood finish. The whisky that put Suntory on the global map.' },
      { name: 'Hibiki 30', proof: '43%', age: '30 yr', pour: '$340 / oz', notes: 'Last allocation, 2019. We have nine ounces remaining as of October.' },
      { name: 'Karuizawa 1980', proof: '57.7%', age: '35 yr', pour: '$795 / oz', notes: 'Ghost distillery, closed 2001. Single-cask, single-vintage. Drink it slowly.' },
      { name: 'Hakushu 18', proof: '43%', age: '18 yr', pour: '$95 / oz', notes: 'Forested, herbal, lightly smoked. The Highland Park of Japan.' },
      { name: 'Nikka Coffey Grain', proof: '45%', age: 'NAS', pour: '$28 / oz', notes: 'Continuous-still grain whisky. The opening pour of the flight, every time.' },
    ],
  },
  {
    region: 'Islay & The Hebrides',
    blurb: 'Peat, brine, and iodine. The Islay shelf takes up an entire wall. Most of what we pour comes from independent bottlings — Signatory, Cadenhead’s, Gordon & MacPhail — at cask strength.',
    items: [
      { name: 'Ardbeg 1975 Single Cask', proof: '49.8%', age: '37 yr', pour: '$425 / oz', notes: 'Cask #1135. Bottled for the Feis Ile 2013. Iodine, sea-spray, ash.' },
      { name: 'Lagavulin 16', proof: '43%', age: '16 yr', pour: '$32 / oz', notes: 'The Lagavulin. Smoke, dried fig, sea salt. The bourbon-drinker’s gateway to peat.' },
      { name: 'Bowmore 25', proof: '43%', age: '25 yr', pour: '$165 / oz', notes: 'Sherry-cask matured. Tropical fruit, salted chocolate, soft peat. Unexpectedly graceful.' },
      { name: 'Bruichladdich Octomore 14.1', proof: '59.6%', age: '5 yr', pour: '$48 / oz', notes: 'The most heavily peated whisky on Earth at 128.9 ppm. Drinks lighter than it reads.' },
      { name: 'Caol Ila 1984 (Signatory)', proof: '54.3%', age: '32 yr', pour: '$220 / oz', notes: 'Independent bottling. Refill bourbon. Sea-smoke, lemon zest, pipe tobacco.' },
    ],
  },
  {
    region: 'The Highlands & Speyside',
    blurb: 'The heart of Scotch. We pour the classics, but the depth of this category sits in the independent bottlings — single casks from Glen Grant, Glenfarclas, Mortlach, and the closed Glenugie distillery.',
    items: [
      { name: 'Glenfarclas 105 Family Cask 1973', proof: '60%', age: '46 yr', pour: '$295 / oz', notes: 'Single ex-sherry hogshead, bottled at cask strength. Christmas cake in liquid form.' },
      { name: 'Macallan 18 Sherry Oak', proof: '43%', age: '18 yr', pour: '$95 / oz', notes: 'The most-poured 18-year on the list. Always in stock.' },
      { name: 'Glen Grant 1965 (Gordon & MacPhail)', proof: '40%', age: '54 yr', pour: '$385 / oz', notes: 'Refill American oak. Beeswax, dried apricot, faint smoke. A whisky for slow conversation.' },
      { name: 'Mortlach 16 Cask Strength', proof: '57%', age: '16 yr', pour: '$72 / oz', notes: '“The Beast of Dufftown.” Meaty, sulphured, complex. Drinks at proof, then opens with water.' },
      { name: 'Aberlour A’bunadh Batch 75', proof: '60.7%', age: 'NAS', pour: '$28 / oz', notes: 'Sherry-cask bruiser. The best $28-pour on the list. Don’t skip it.' },
    ],
  },
  {
    region: 'American & The Outliers',
    blurb: 'Pre-Prohibition bourbon, single-cask rye, and the strange one-offs we love — Welsh, Indian, Taiwanese, Australian. The collection that surprises every Scotch drinker who wanders into it.',
    items: [
      { name: 'Pappy Van Winkle 23', proof: '47.8%', age: '23 yr', pour: '$485 / oz', notes: 'Allocation we received in 2018. We have approximately one bottle left.' },
      { name: 'Willett Family Estate 22-Year Rye', proof: '54.5%', age: '22 yr', pour: '$245 / oz', notes: 'Single-barrel selection. Dark caramel, cardamom, leather. The best American rye on the shelf.' },
      { name: 'Stitzel-Weller 1959 Distillation', proof: '43%', age: '12 yr', pour: '$320 / oz', notes: 'Pre-merger Stitzel-Weller, bottled 1971. Wheated mash bill, the original Pappy DNA.' },
      { name: 'Kavalan Solist Vinho Barrique', proof: '57.1%', age: 'NAS', pour: '$58 / oz', notes: 'Single-cask Taiwanese whisky finished in red-wine barriques. Mango, tannin, cocoa.' },
      { name: 'Amrut Greedy Angels 12', proof: '55%', age: '12 yr', pour: '$95 / oz', notes: 'Indian single malt, aged through monsoon humidity — equivalent to a 30-year Scotch.' },
      { name: 'Sullivan’s Cove French Oak', proof: '47.5%', age: 'NAS', pour: '$165 / oz', notes: 'Single-cask Tasmanian. World Whisky of the Year, 2014. Dried fruit, leather, sandalwood.' },
    ],
  },
];

const flights = [
  { name: 'A Tour of Islay', price: '$125', desc: 'Caol Ila 12, Lagavulin 16, Ardbeg Uigeadail. Three pours, north to south. Forty minutes of peat at the bar.' },
  { name: 'The Japanese Flight', price: '$165', desc: 'Hakushu 18, Yamazaki 18, Nikka Yoichi 15. Highland, sherry-cask, peated. A guided tour of the four houses.' },
  { name: 'Bourbon Vertical', price: '$95', desc: 'Four expressions from the same Kentucky distillery at four ages — 8, 12, 17, and 23 years. You taste a single barrel grow up.' },
  { name: 'The Outliers', price: '$140', desc: 'Three world whiskies you’ve never had. Selections change weekly based on what just landed in the cellar.' },
  { name: 'The Bartender’s Reserve', price: '$245', desc: 'Three rare pours, no menu. The bartender selects based on what you drink, what you say, and what they have an open bottle of. Reservation required.' },
];

const philosophy = [
  { num: '1,200+', label: 'Single bottles in the library' },
  { num: '47', label: 'Closed-distillery expressions' },
  { num: '2014', label: 'Year we started collecting' },
  { num: 'No', label: 'Bottle is opened twice — what’s open is what’s available' },
];
---

<Layout restaurant={restaurant} theme="v5" fontUrl={FONT_URL} title={pageTitle}>

<style>
  :root {
    --v5-black:       #0B0A08;
    --v5-surface:     #141210;
    --v5-surface-2:   #1C1916;
    --v5-gold:        #C9A84C;
    --v5-gold-light:  #E5C97A;
    --v5-copper:      #B87333;
    --v5-white:       #EDE8DE;
    --v5-muted:       #8B7F70;
    --v5-border:      rgba(237,232,222,0.08);
    --v5-border-gold: rgba(201,168,76,0.25);
  }
  body { background: var(--v5-black); color: var(--v5-white); font-family: 'Montserrat', sans-serif; -webkit-font-smoothing: antialiased; }

  /* NAV */
  .v5-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1.5rem 3rem; display: flex; align-items: center; justify-content: space-between; background: rgba(11,10,8,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--v5-border); }
  .v5-nav__monogram { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--v5-gold); text-decoration: none; letter-spacing: 0.25em; }
  .v5-nav__links { display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; }
  .v5-nav__links a { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--v5-muted); text-decoration: none; font-weight: 400; transition: color 0.2s; }
  .v5-nav__links a:hover { color: var(--v5-white); }
  .v5-nav__links a.active { color: var(--v5-gold); border-bottom: 1px solid var(--v5-gold); padding-bottom: 3px; }
  .v5-nav__links a.reserve { color: var(--v5-gold); }

  /* HERO */
  .wsk-hero { padding: 11rem 3rem 6rem; position: relative; background: radial-gradient(ellipse at 50% 30%, rgba(201,168,76,0.08), transparent 60%), var(--v5-black); border-bottom: 1px solid var(--v5-border-gold); text-align: center; overflow: hidden; }
  .wsk-eyebrow { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 0.55em; text-transform: uppercase; color: var(--v5-gold); margin-bottom: 1.5rem; font-weight: 400; }
  .wsk-h1 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: clamp(3rem, 7vw, 6rem); line-height: 1; color: var(--v5-white); margin: 0; letter-spacing: -0.01em; }
  .wsk-h1 .v5-gold { color: var(--v5-gold); }
  .wsk-rule { display: block; width: 80px; height: 1px; background: var(--v5-gold); margin: 2rem auto; opacity: 0.6; }
  .wsk-lede { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: clamp(1.05rem, 1.5vw, 1.3rem); line-height: 1.7; color: rgba(237,232,222,0.7); max-width: 42rem; margin: 0 auto; }

  /* STATS */
  .wsk-stats { padding: 4rem 3rem; background: var(--v5-surface); border-top: 1px solid var(--v5-border-gold); border-bottom: 1px solid var(--v5-border-gold); }
  .wsk-stats__inner { max-width: 64rem; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 2.5rem; }
  .wsk-stat { text-align: center; }
  .wsk-stat__num { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: clamp(2rem, 4vw, 3.2rem); color: var(--v5-gold); line-height: 1; margin-bottom: 0.5rem; }
  .wsk-stat__label { font-family: 'Montserrat', sans-serif; font-size: 0.75rem; letter-spacing: 0.15em; color: var(--v5-muted); font-weight: 300; line-height: 1.5; }

  /* LETTER */
  .wsk-letter { padding: 6rem 3rem; background: var(--v5-black); }
  .wsk-letter__inner { max-width: 48rem; margin: 0 auto; }
  .wsk-letter h2 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); color: var(--v5-gold); margin: 0 0 2rem; line-height: 1.15; }
  .wsk-letter p { font-family: 'Montserrat', sans-serif; font-size: 0.98rem; line-height: 1.85; color: rgba(237,232,222,0.78); font-weight: 300; margin: 0 0 1.25rem; }
  .wsk-letter p.lede { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.4rem; color: rgba(237,232,222,0.9); }
  .wsk-letter .sig { border-top: 1px solid var(--v5-border-gold); padding-top: 1.5rem; margin-top: 2.5rem; display: flex; align-items: baseline; gap: 1rem; }
  .wsk-letter .sig-name { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.4rem; color: var(--v5-gold); }
  .wsk-letter .sig-meta { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--v5-muted); font-weight: 400; }

  /* FLIGHTS */
  .wsk-flights { padding: 6rem 3rem; background: var(--v5-surface); }
  .wsk-flights__inner { max-width: 64rem; margin: 0 auto; }
  .wsk-section-head { text-align: center; margin-bottom: 3.5rem; }
  .wsk-section-label { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 0.45em; text-transform: uppercase; color: var(--v5-gold); margin-bottom: 1rem; font-weight: 400; }
  .wsk-section-h2 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: clamp(2.2rem, 5vw, 3.6rem); color: var(--v5-white); margin: 0; line-height: 1; }

  .flight { padding: 1.75rem 0; border-bottom: 1px solid var(--v5-border); display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: baseline; }
  .flight:first-child { border-top: 1px solid var(--v5-border); }
  .flight__name { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.55rem; color: var(--v5-gold-light); margin: 0 0 0.4rem; line-height: 1.1; }
  .flight__desc { font-family: 'Montserrat', sans-serif; font-size: 0.92rem; font-weight: 300; line-height: 1.7; color: rgba(237,232,222,0.7); margin: 0; }
  .flight__price { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--v5-gold); white-space: nowrap; }

  /* LIBRARY */
  .wsk-library { padding: 6rem 3rem; background: var(--v5-black); }
  .wsk-library__inner { max-width: 64rem; margin: 0 auto; }
  .lib-section { margin-bottom: 4.5rem; }
  .lib-section__head { display: flex; align-items: baseline; gap: 1.25rem; margin-bottom: 1rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--v5-border-gold); }
  .lib-section__region { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 2rem; color: var(--v5-gold); white-space: nowrap; }
  .lib-section__rule { flex: 1; height: 1px; background: var(--v5-border-gold); }
  .lib-section__blurb { font-family: 'Montserrat', sans-serif; font-size: 0.92rem; font-weight: 300; line-height: 1.8; color: rgba(237,232,222,0.65); margin: 0 0 2rem; max-width: 44rem; }

  .bottle { padding: 1.5rem 0; border-bottom: 1px solid var(--v5-border); display: grid; grid-template-columns: 1.4fr 1fr auto; gap: 2rem; align-items: baseline; }
  .bottle__main { }
  .bottle__name { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; color: var(--v5-white); font-weight: 500; margin: 0 0 0.3rem; line-height: 1.2; }
  .bottle__notes { font-family: 'Montserrat', sans-serif; font-size: 0.85rem; font-weight: 300; line-height: 1.7; color: var(--v5-muted); margin: 0; }
  .bottle__specs { font-family: 'Montserrat', sans-serif; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(201,168,76,0.7); }
  .bottle__specs span + span::before { content: '·'; margin: 0 0.5rem; color: var(--v5-muted); }
  .bottle__pour { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--v5-gold); text-align: right; white-space: nowrap; }

  /* SERVICE */
  .wsk-service { padding: 6rem 3rem; background: var(--v5-surface-2); }
  .wsk-service__inner { max-width: 48rem; margin: 0 auto; text-align: center; }
  .wsk-service h2 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); color: var(--v5-gold); margin: 0 0 1.5rem; line-height: 1.15; }
  .wsk-service p { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.15rem; line-height: 1.75; color: rgba(237,232,222,0.85); margin: 0 0 1.25rem; }

  /* CTA */
  .wsk-cta { padding: 6rem 3rem; background: var(--v5-black); text-align: center; border-top: 1px solid var(--v5-border-gold); }
  .wsk-cta__inner { max-width: 40rem; margin: 0 auto; }
  .wsk-cta h2 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: clamp(2.2rem, 5vw, 3.4rem); color: var(--v5-white); margin: 0 0 1.5rem; }
  .wsk-cta p { font-family: 'Montserrat', sans-serif; font-size: 0.95rem; font-weight: 300; color: var(--v5-muted); margin: 0 0 2.5rem; line-height: 1.7; }
  .wsk-cta__btns { display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
  .btn { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 0.35em; text-transform: uppercase; font-weight: 400; padding: 1.1rem 2.4rem; text-decoration: none; transition: background 0.25s, color 0.25s, border-color 0.25s; }
  .btn-primary { background: var(--v5-gold); color: var(--v5-black); }
  .btn-primary:hover { background: var(--v5-gold-light); }
  .btn-ghost { background: transparent; color: var(--v5-gold); border: 1px solid var(--v5-gold); }
  .btn-ghost:hover { background: var(--v5-gold); color: var(--v5-black); }

  /* FOOTER */
  .v5-footer { padding: 3rem 3rem; background: var(--v5-black); border-top: 1px solid var(--v5-border); text-align: center; }
  .v5-footer__links { display: flex; gap: 2rem; flex-wrap: wrap; justify-content: center; list-style: none; margin: 0 0 1.5rem; padding: 0; }
  .v5-footer__links a { font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--v5-muted); text-decoration: none; }
  .v5-footer__links a:hover { color: var(--v5-gold); }
  .v5-footer__copy { font-family: 'Montserrat', sans-serif; font-size: 0.72rem; color: rgba(237,232,222,0.3); }

  @media (max-width: 768px) {
    .v5-nav { padding: 1rem 1.25rem; }
    .v5-nav__links { display: none; }
    .wsk-hero, .wsk-stats, .wsk-letter, .wsk-flights, .wsk-library, .wsk-service, .wsk-cta { padding-left: 1.25rem; padding-right: 1.25rem; }
    .wsk-hero { padding-top: 7.5rem; padding-bottom: 4rem; }
    .wsk-stats__inner { grid-template-columns: repeat(2, 1fr); gap: 1.75rem; }
    .flight, .bottle { grid-template-columns: 1fr; gap: 0.5rem; }
    .bottle__pour, .flight__price { text-align: left; }
    .lib-section__head { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .lib-section__rule { width: 100%; }
  }
</style>

<!-- NAV -->
<nav class="v5-nav" aria-label="Primary">
  <a href="/v5-dark-elegant" class="v5-nav__monogram">E</a>
  <ul class="v5-nav__links">
    <li><a href="/v5-dark-elegant#v5-menu">Menu</a></li>
    <li><a href="/v5-dark-elegant/whisky" class="active">Whisky</a></li>
    <li><a href="/v5-dark-elegant#v5-about">Story</a></li>
    <li><a href="/v5-dark-elegant#v5-reserve" class="reserve">Reserve</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="wsk-hero" aria-label="The Whisky Library">
  <p class="wsk-eyebrow">The Library at Ember</p>
  <h1 class="wsk-h1">A thousand bottles.<br/><span class="v5-gold">One conversation at a time.</span></h1>
  <span class="wsk-rule" aria-hidden="true"></span>
  <p class="wsk-lede">Ember holds one of the largest privately curated whisky collections in the Midwest. Twelve hundred bottles. Forty-seven closed-distillery expressions. A program built over a decade by people who would rather pour than collect.</p>
</section>

<!-- STATS -->
<section class="wsk-stats" aria-label="The library at a glance">
  <div class="wsk-stats__inner">
    {philosophy.map((p) => (
      <div class="wsk-stat">
        <div class="wsk-stat__num">{p.num}</div>
        <div class="wsk-stat__label">{p.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- LETTER -->
<section class="wsk-letter" aria-label="From the bar program">
  <div class="wsk-letter__inner">
    <h2>A library is not a museum.</h2>
    <p class="lede">A whisky list should be a working document — alive, opinionated, and a little dangerous. Every bottle on this list is open. Every bottle was poured for someone last night, and will be poured for someone tomorrow.</p>
    <p>We started buying bottles in 2014, when the Japanese market was quiet and the Islay distilleries were still releasing single-cask editions at sensible prices. We did not collect. We bought what we wanted to drink, and we poured it for the people who came in.</p>
    <p>Some bottles got rare. The Karuizawas, the pre-merger Stitzel-Wellers, the Ardbeg single casks from the 1970s. We did not raise their prices to match the secondary market. We raised them enough to cover the bottle when it’s empty, and we keep them open until someone takes the last pour. If the last pour goes to a guest celebrating thirty years of marriage, we’re happy. If it goes to a young woman who just turned twenty-one and asked the bartender what to start with, we’re happier.</p>
    <p>The flights below are a starting point. The real list lives on a clipboard behind the bar, gets updated every Friday, and has notes in the margins. Ask for it. Ask the bartender what they’ve been thinking about. The library opens for anyone who wants in.</p>
    <div class="sig">
      <span class="sig-name">Henry Okafor</span>
      <span class="sig-meta">Bar Director · Ember</span>
    </div>
  </div>
</section>

<!-- FLIGHTS -->
<section class="wsk-flights" aria-label="Flights">
  <div class="wsk-flights__inner">
    <div class="wsk-section-head">
      <p class="wsk-section-label">A way in</p>
      <h2 class="wsk-section-h2">Curated flights.</h2>
    </div>
    {flights.map((f) => (
      <article class="flight">
        <div>
          <h3 class="flight__name">{f.name}</h3>
          <p class="flight__desc">{f.desc}</p>
        </div>
        <div class="flight__price">{f.price}</div>
      </article>
    ))}
  </div>
</section>

<!-- LIBRARY -->
<section class="wsk-library" aria-label="The whisky library">
  <div class="wsk-library__inner">
    <div class="wsk-section-head">
      <p class="wsk-section-label">By region</p>
      <h2 class="wsk-section-h2">The library, abbreviated.</h2>
    </div>
    {sections.map((section) => (
      <div class="lib-section">
        <div class="lib-section__head">
          <span class="lib-section__region">{section.region}</span>
          <span class="lib-section__rule" aria-hidden="true"></span>
        </div>
        <p class="lib-section__blurb">{section.blurb}</p>
        {section.items.map((b) => (
          <article class="bottle">
            <div class="bottle__main">
              <h4 class="bottle__name">{b.name}</h4>
              <p class="bottle__notes">{b.notes}</p>
            </div>
            <div class="bottle__specs">
              <span>{b.age}</span>
              <span>{b.proof}</span>
            </div>
            <div class="bottle__pour">{b.pour}</div>
          </article>
        ))}
      </div>
    ))}
  </div>
</section>

<!-- SERVICE -->
<section class="wsk-service" aria-label="How we serve">
  <div class="wsk-service__inner">
    <h2>How a pour arrives at your table.</h2>
    <p>Every pour is measured at one ounce, served neat in cut crystal, with water from a single-source spring in Wisconsin. No ice unless you ask. The pipette is on the table. The bartender will tell you what cask the whisky came from and what they smell when they pour it. You will not be rushed.</p>
    <p>If a bottle on this list runs out tonight, the bartender will tell you what they’d open next from the back room — and they probably won’t charge you the full price of the substitute. That’s the deal we’ve made with our regulars.</p>
  </div>
</section>

<!-- CTA -->
<section class="wsk-cta" aria-label="Reserve at the bar">
  <div class="wsk-cta__inner">
    <h2>Take a seat at the bar.</h2>
