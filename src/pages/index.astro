---
import '../global.css';

const templates = [
  {
    slug: 'v1-warm-italian',
    num: '01',
    name: 'Bella Sole',
    style: 'Warm Italian',
    description: 'Terracotta & cream. Playfair Display. Candlelit full-bleed hero anchored to the viewport floor.',
    cuisine: 'Coastal Italian · La Jolla, CA',
    image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1200&q=80',
    accent: '#C4714A',
    bg: '#FDFAF4',
    text: '#1C1208',
    textMuted: '#8F8070',
  },
  {
    slug: 'v2-modern-minimal',
    num: '02',
    name: 'North & Pine',
    style: 'Modern Minimal',
    description: 'Near-mono palette. DM Serif Display. Split-panel hero — image right, text left, extreme whitespace.',
    cuisine: 'Contemporary American · West Village, NYC',
    image: 'https://images.unsplash.com/photo-1476224203421-74177f72b58c?auto=format&fit=crop&w=800&q=80',
    accent: '#1A3A2E',
    bg: '#FAFAF8',
    text: '#0C0C0A',
    textMuted: '#888880',
  },
  {
    slug: 'v3-rustic-farm',
    num: '03',
    name: 'Hen & Hearth',
    style: 'Rustic Farm',
    description: 'Warm parchment, earthy tones. Libre Baskerville italic. Border-left gold accent on hero.',
    cuisine: 'Farm-to-Table · Woodstock, VT',
    image: 'https://images.unsplash.com/photo-1473093226795-af9932fe5856?auto=format&fit=crop&w=800&q=80',
    accent: '#7A5230',
    bg: '#F8F3E8',
    text: '#2A1A0A',
    textMuted: '#8A7860',
  },
  {
    slug: 'v4-bold-color',
    num: '04',
    name: 'Casa Verde',
    style: 'Bold Color',
    description: 'Vivid red-orange overlay. Oswald at 10rem, uppercase. High-energy Mediterranean contrast.',
    cuisine: 'Modern Mediterranean · Echo Park, LA',
    image: 'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=800&q=80',
    accent: '#D64A1A',
    bg: '#FFFEF9',
    text: '#180A00',
    textMuted: '#6B5A48',
  },
  {
    slug: 'v5-dark-elegant',
    num: '05',
    name: 'Ember',
    style: 'Dark Elegant',
    description: 'Near-black with gold. Cormorant Garamond. Dramatic moody steakhouse luxury.',
    cuisine: 'Prime Steaks & Spirits · River North, Chicago',
    image: 'https://images.unsplash.com/photo-1600891964092-4316c288032e?auto=format&fit=crop&w=800&q=80',
    accent: '#C9A84C',
    bg: '#0B0A08',
    text: '#EDE8DE',
    textMuted: '#6A6258',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="5 distinct restaurant website templates — Warm Italian, Modern Minimal, Rustic Farm, Bold Color, Dark Elegant. Each is a complete, deployable site." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <title>Restaurant Templates — 5 Distinct Designs</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: #080706;
        color: #EDE8DE;
        font-family: 'DM Sans', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      /* ── Animated background grain ── */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 0;
      }

      /* ── Radial glow behind header ── */
      .header-glow {
        position: absolute;
        top: -120px;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 600px;
        background: radial-gradient(ellipse at center, rgba(201,168,76,0.07) 0%, transparent 70%);
        pointer-events: none;
      }

      /* ── Header ── */
      header {
        position: relative;
        max-width: 72rem;
        margin: 0 auto;
        padding: clamp(5rem, 9vw, 8rem) 1.5rem clamp(3rem, 5vw, 5rem);
        text-align: center;
        z-index: 1;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.48em;
        text-transform: uppercase;
        color: #C9A84C;
        margin-bottom: 1.75rem;
        opacity: 0;
        animation: fadeInDown 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s forwards;
      }
      .eyebrow::before, .eyebrow::after {
        content: '';
        display: block;
        width: 2rem;
        height: 1px;
        background: currentColor;
        opacity: 0.5;
      }

      h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(2.75rem, 6.5vw, 5.5rem);
        font-weight: 400;
        line-height: 1.06;
        color: #EDE8DE;
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: fadeInDown 0.8s cubic-bezier(0.22,1,0.36,1) 0.22s forwards;
      }
      h1 em {
        font-style: italic;
        color: rgba(237,232,222,0.55);
      }

      .header-sub {
        font-size: 0.9375rem;
        line-height: 1.75;
        color: rgba(237,232,222,0.36);
        max-width: 30rem;
        margin: 0 auto 0;
        font-weight: 300;
        opacity: 0;
        animation: fadeInDown 0.8s cubic-bezier(0.22,1,0.36,1) 0.34s forwards;
      }

      /* ── Grid ── */
      main {
        position: relative;
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1.25rem clamp(5rem, 10vw, 8rem);
        z-index: 1;
      }

      /* Horizontal rule separator */
      .grid-rule {
        width: 100%;
        height: 1px;
        background: rgba(237,232,222,0.07);
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeIn 1s ease 0.5s forwards;
      }

      .row1 { display: grid; grid-template-columns: 3fr 2fr; gap: 1px; background: rgba(237,232,222,0.07); }
      .row2 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(237,232,222,0.07); margin-top: 1px; }

      @media (max-width: 768px) {
        .row1 { grid-template-columns: 1fr; }
        .row2 { grid-template-columns: 1fr 1fr; }
      }
      @media (max-width: 480px) {
        .row2 { grid-template-columns: 1fr; }
      }

      /* ── Cards ── */
      .card {
        display: block;
        text-decoration: none;
        background: #0D0C0A;
        overflow: hidden;
        transition: background 0.3s;
        opacity: 0;
        animation: fadeInUp 0.75s cubic-bezier(0.22,1,0.36,1) var(--delay, 0.4s) forwards;
      }
      .card:hover { background: #131110; }
      .card:hover .card-img { transform: scale(1.05); }
      .card:hover .card-num { opacity: 1; }
      .card:hover .card-arrow { transform: translate(3px, -3px); }

      .card-img-wrap { overflow: hidden; position: relative; }
      .card-img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      /* Color accent strip along bottom of image */
      .card-img-wrap::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(8,7,6,0.6) 0%, transparent 50%);
        pointer-events: none;
      }

      .card-num {
        position: absolute;
        top: 1rem;
        left: 1rem;
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.3em;
        color: white;
        opacity: 0.5;
        transition: opacity 0.2s;
        z-index: 1;
        font-family: 'DM Sans', system-ui, sans-serif;
      }

      .card-info {
        padding: 1.375rem 1.5rem 1.75rem;
        border-top: 1px solid rgba(237,232,222,0.07);
      }

      .card-style {
        font-size: 0.575rem;
        font-weight: 500;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        margin-bottom: 0.3rem;
      }

      .card-name {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 400;
        color: #EDE8DE;
        line-height: 1.15;
        margin-bottom: 0.625rem;
      }

      .card-desc {
        font-size: 0.78rem;
        line-height: 1.6;
        margin-bottom: 0.5rem;
        font-weight: 300;
      }

      .card-cuisine {
        font-size: 0.67rem;
        opacity: 0.5;
        letter-spacing: 0.05em;
      }

      .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.125rem;
        padding-top: 0.875rem;
        border-top: 1px solid rgba(237,232,222,0.07);
      }

      .card-cta {
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.3em;
        text-transform: uppercase;
      }

      .card-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 50%;
        transition: transform 0.25s cubic-bezier(0.22,1,0.36,1);
        flex-shrink: 0;
      }

      /* ── Footer ── */
      footer {
        position: relative;
        z-index: 1;
        border-top: 1px solid rgba(237,232,222,0.06);
        padding: 2.25rem 1.5rem;
        text-align: center;
      }
      footer p {
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(237,232,222,0.16);
      }
      footer a { color: inherit; text-decoration: none; }
      footer a:hover { color: rgba(237,232,222,0.38); }

      /* ── Keyframes ── */
      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-16px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @media (prefers-reduced-motion: reduce) {
        .card, .eyebrow, h1, .header-sub, .grid-rule { animation: none; opacity: 1; transform: none; }
      }
    </style>
  </head>
  <body>

    <!-- Header -->
    <header>
      <div class="header-glow" aria-hidden="true"></div>
      <p class="eyebrow">Restaurant Templates</p>
      <h1>Five Distinct<br /><em>Restaurant Designs</em></h1>
      <p class="header-sub">Each template is a complete restaurant website. Swap one data file to make it yours.</p>
    </header>

    <!-- Grid -->
    <main>
      <div class="grid-rule" aria-hidden="true"></div>

      <!-- Row 1: V1 (featured large) + V2 -->
      <div class="row1">
        {templates.slice(0, 2).map((t, i) => (
          <a href={`/${t.slug}`} class="card" style={`--delay: ${0.45 + i * 0.1}s;`}>
            <div class="card-img-wrap" style={`height: ${i === 0 ? 'clamp(280px, 36vw, 500px)' : 'clamp(220px, 24vw, 340px)'};`}>
              <span class="card-num">{t.num}</span>
              <img
                src={t.image}
                alt={`${t.name} — ${t.style} template preview`}
                class="card-img"
                loading="eager"
                decoding="async"
              />
            </div>
            <div class="card-info">
              <p class="card-style" style={`color: ${t.accent};`}>{t.style}</p>
              <h2 class="card-name" style={`font-size: ${i === 0 ? '1.625rem' : '1.375rem'}; color: ${t.text === '#0B0A08' || t.text === '#0C0C0A' ? '#EDE8DE' : t.text};`}>{t.name}</h2>
              <p class="card-desc" style={`color: rgba(237,232,222,0.45);`}>{t.description}</p>
              <p class="card-cuisine" style={`color: ${t.accent};`}>{t.cuisine}</p>
              <div class="card-footer">
                <span class="card-cta" style={`color: rgba(237,232,222,0.35);`}>View template</span>
                <span class="card-arrow" style={`background: ${t.accent};`} aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Row 2: V3, V4, V5 -->
      <div class="row2">
        {templates.slice(2).map((t, i) => (
          <a href={`/${t.slug}`} class="card" style={`--delay: ${0.55 + i * 0.08}s;`}>
            <div class="card-img-wrap" style="height: clamp(180px, 18vw, 260px);">
              <span class="card-num">{t.num}</span>
              <img
                src={t.image}
                alt={`${t.name} — ${t.style} template preview`}
                class="card-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="card-info">
              <p class="card-style" style={`color: ${t.accent};`}>{t.style}</p>
              <h2 class="card-name" style={`font-size: 1.25rem; color: ${t.text === '#0B0A08' || t.text === '#180A00' || t.text === '#2A1A0A' ? '#EDE8DE' : t.text};`}>{t.name}</h2>
              <p class="card-desc" style="color: rgba(237,232,222,0.45);">{t.description}</p>
              <p class="card-cuisine" style={`color: ${t.accent};`}>{t.cuisine}</p>
              <div class="card-footer">
                <span class="card-cta" style="color: rgba(237,232,222,0.35);">View template</span>
                <span class="card-arrow" style={`background: ${t.accent}; width: 1.5rem; height: 1.5rem;`} aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer>
      <p>Astro · Tailwind CSS v4 · Photos: <a href="https://unsplash.com" target="_blank" rel="noopener noreferrer">Unsplash</a></p>
    </footer>

  </body>
</html>
