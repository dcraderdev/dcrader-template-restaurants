---
import '../global.css';

const templates = [
  {
    slug: 'v1-warm-italian',
    name: 'Bella Sole',
    style: 'Warm Italian',
    description: 'Terracotta & cream. Playfair Display. Classic, candlelit warmth for an Italian coastal restaurant.',
    cuisine: 'Coastal Italian · La Jolla, CA',
    image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1200&q=80',
    accent: '#C4714A',
    bg: '#FDFAF4',
    text: '#1C1208',
    textMuted: '#8F8070',
  },
  {
    slug: 'v2-modern-minimal',
    name: 'North & Pine',
    style: 'Modern Minimal',
    description: 'Near-mono palette. DM Serif Display. Split-panel hero. Extreme whitespace.',
    cuisine: 'Contemporary American · West Village, NYC',
    image: 'https://images.unsplash.com/photo-1476224203421-74177f72b58c?auto=format&fit=crop&w=800&q=80',
    accent: '#1A3A2E',
    bg: '#FAFAF8',
    text: '#0C0C0A',
    textMuted: '#888880',
  },
  {
    slug: 'v3-rustic-farm',
    name: 'Hen & Hearth',
    style: 'Rustic Farm',
    description: 'Warm parchment, earthy tones. Libre Baskerville italic. Border-left hero accent.',
    cuisine: 'Farm-to-Table · Woodstock, VT',
    image: 'https://images.unsplash.com/photo-1473093226795-af9932fe5856?auto=format&fit=crop&w=800&q=80',
    accent: '#7A5230',
    bg: '#F8F3E8',
    text: '#2A1A0A',
    textMuted: '#8A7860',
  },
  {
    slug: 'v4-bold-color',
    name: 'Casa Verde',
    style: 'Bold Color',
    description: 'Vivid red-orange overlay. Oswald at 10rem. High energy Mediterranean contrast.',
    cuisine: 'Modern Mediterranean · Echo Park, LA',
    image: 'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=800&q=80',
    accent: '#D64A1A',
    bg: '#FFFEF9',
    text: '#180A00',
    textMuted: '#6B5A48',
  },
  {
    slug: 'v5-dark-elegant',
    name: 'Ember',
    style: 'Dark Elegant',
    description: 'Near-black with gold. Cormorant Garamond. Dramatic moody steakhouse luxury.',
    cuisine: 'Prime Steaks & Spirits · River North, Chicago',
    image: 'https://images.unsplash.com/photo-1600891964092-4316c288032e?auto=format&fit=crop&w=800&q=80',
    accent: '#C9A84C',
    bg: '#0B0A08',
    text: '#EDE8DE',
    textMuted: '#6A6258',
  },
];

const row1 = templates.slice(0, 2);
const row2 = templates.slice(2);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="5 distinct restaurant website templates — Warm Italian, Modern Minimal, Rustic Farm, Bold Color, Dark Elegant. Each is a complete, deployable site." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <title>Restaurant Templates — 5 Distinct Designs</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        background: #0A0908;
        color: #EDE8DE;
        font-family: 'Inter', system-ui, sans-serif;
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }
      .card { display: block; text-decoration: none; overflow: hidden; transition: opacity 0.2s; }
      .card:hover { opacity: 0.93; }
      .card-img { display: block; width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
      .card:hover .card-img { transform: scale(1.04); }
      .card-img-wrap { overflow: hidden; }
      .row1 { display: grid; grid-template-columns: 3fr 2fr; gap: 1.25rem; }
      .row2 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 1.25rem; }
      @media (max-width: 768px) {
        .row1 { grid-template-columns: 1fr; }
        .row2 { grid-template-columns: 1fr 1fr; }
      }
      @media (max-width: 480px) {
        .row2 { grid-template-columns: 1fr; }
      }
      .card-info { padding: 1.25rem 1.5rem 1.5rem; }
      .arrow-circle {
        flex-shrink: 0;
        width: 1.875rem; height: 1.875rem;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
      }
    </style>
  </head>
  <body>

    <!-- Header -->
    <header style="max-width: 72rem; margin: 0 auto; padding: clamp(3rem,6vw,5rem) 1.5rem clamp(2rem,4vw,3.5rem); text-align: center;">
      <p style="font-size: 0.65rem; font-weight: 600; letter-spacing: 0.45em; text-transform: uppercase; color: #C9A84C; margin: 0 0 1.25rem;">Restaurant Templates</p>
      <h1 style="font-family: 'Playfair Display', serif; font-size: clamp(2.25rem, 5.5vw, 4.25rem); line-height: 1.08; color: #EDE8DE; margin: 0 0 1.25rem; font-weight: 400;">
        Five Distinct<br /><em style="color: rgba(237,232,222,0.75);">Restaurant Designs</em>
      </h1>
      <p style="font-size: 0.9375rem; line-height: 1.75; color: rgba(237,232,222,0.42); max-width: 34rem; margin: 0 auto;">
        Each template is a complete restaurant website. Swap one data file to personalize for any establishment.
      </p>
    </header>

    <!-- Grid -->
    <main style="max-width: 78rem; margin: 0 auto; padding: 0 1.25rem clamp(4rem,8vw,7rem);">

      <!-- Row 1: V1 (featured large) + V2 -->
      <div class="row1">
        {row1.map((t, i) => (
          <a href={`/${t.slug}`} class="card" style={`background: ${t.bg};`}>
            <div class="card-img-wrap" style={`height: ${i === 0 ? 'clamp(260px, 34vw, 480px)' : 'clamp(200px, 22vw, 320px)'};`}>
              <img
                src={t.image}
                alt={`${t.name} — ${t.style} template preview`}
                class="card-img"
                loading="eager"
                decoding="async"
              />
            </div>
            <div class="card-info">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.625rem;">
                <div>
                  <p style={`font-size: 0.6rem; font-weight: 600; letter-spacing: 0.38em; text-transform: uppercase; color: ${t.accent}; margin: 0 0 0.2rem;`}>{t.style}</p>
                  <h2 style={`font-family: 'Playfair Display', serif; font-size: ${i === 0 ? '1.625rem' : '1.375rem'}; color: ${t.text}; margin: 0; font-weight: 400;`}>{t.name}</h2>
                </div>
                <span class="arrow-circle" style={`background: ${t.accent};`} aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
              <p style={`font-size: 0.8125rem; line-height: 1.6; color: ${t.textMuted}; margin: 0 0 0.375rem;`}>{t.description}</p>
              <p style={`font-size: 0.7rem; color: ${t.accent}; opacity: 0.65; margin: 0;`}>{t.cuisine}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Row 2: V3, V4, V5 -->
      <div class="row2">
        {row2.map(t => (
          <a href={`/${t.slug}`} class="card" style={`background: ${t.bg};`}>
            <div class="card-img-wrap" style="height: clamp(180px, 18vw, 260px);">
              <img
                src={t.image}
                alt={`${t.name} — ${t.style} template preview`}
                class="card-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="card-info">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.5rem;">
                <div>
                  <p style={`font-size: 0.6rem; font-weight: 600; letter-spacing: 0.38em; text-transform: uppercase; color: ${t.accent}; margin: 0 0 0.2rem;`}>{t.style}</p>
                  <h2 style={`font-family: 'Playfair Display', serif; font-size: 1.25rem; color: ${t.text}; margin: 0; font-weight: 400;`}>{t.name}</h2>
                </div>
                <span class="arrow-circle" style={`background: ${t.accent}; width: 1.625rem; height: 1.625rem;`} aria-hidden="true">
                  <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
              <p style={`font-size: 0.75rem; line-height: 1.55; color: ${t.textMuted}; margin: 0 0 0.3rem;`}>{t.description}</p>
              <p style={`font-size: 0.68rem; color: ${t.accent}; opacity: 0.65; margin: 0;`}>{t.cuisine}</p>
            </div>
          </a>
        ))}
      </div>

    </main>

    <!-- Footer -->
    <footer style="border-top: 1px solid rgba(237,232,222,0.06); padding: 2rem 1.5rem; text-align: center;">
      <p style="font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(237,232,222,0.18); margin: 0;">
        Astro · Tailwind CSS v4 · Unsplash (free commercial license)
      </p>
    </footer>

  </body>
</html>
