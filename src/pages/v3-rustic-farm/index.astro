---
import Layout from '../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { restaurant } from '../../data/restaurants/v3';

const fontUrl = 'https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400;1,9..144,500&family=Caveat:wght@400;600;700&family=Source+Sans+3:wght@300;400;600&display=swap';

const dietaryMap: Record<string, string> = {
  vegetarian: 'V',
  vegan: 'VG',
  'gluten-free': 'GF',
};

// ── Menu-led hero: pair first 6 dishes with gallery images ──
const heroDishes = (() => {
  const allItems = restaurant.menu.categories.flatMap((c) => c.items);
  const pics = restaurant.gallery;
  return [0, 1, 2, 3, 4, 5].map((i) => ({
    item: allItems[i % allItems.length],
    image: pics[i % pics.length],
  }));
})();
---

<Layout restaurant={restaurant} theme="v3" fontUrl={fontUrl}>

<!-- ==================== NAV ==================== -->
<nav class="v3-nav" id="v3-nav">
  <a href="#" class="v3-nav-logo">Hen &amp; Hearth</a>
  <button class="v3-hamburger" id="v3-hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Full-screen nav overlay -->
<div class="v3-nav-overlay" id="v3-nav-overlay" aria-hidden="true">
  <button class="v3-nav-close" id="v3-nav-close" aria-label="Close menu">&times;</button>
  <nav class="v3-overlay-links">
    <a href="#menu" class="v3-overlay-link">Menu</a>
    <a href="#gallery" class="v3-overlay-link">Gallery</a>
    <a href="#about" class="v3-overlay-link">Our Story</a>
    <a href="#reservations" class="v3-overlay-link">Reserve</a>
    <a href="#contact" class="v3-overlay-link">Visit</a>
  </nav>
  <span class="v3-overlay-est">Est. 2018</span>
</div>

<!-- ==================== HERO — MENU-LED GRID TREATMENT ==================== -->
<section class="v3-hero v3-hero--menu" id="home" aria-label="This week on the menu">
  <header class="v3-hero-grid-header">
    <span class="v3-hero-eyebrow">Est. 2018 · Woodstock, VT · {restaurant.cuisine}</span>
    <h1 class="v3-hero-grid-h1">
      This week<br/><em>on the hearth</em>
    </h1>
    <p class="v3-hero-grid-sub">{restaurant.heroSubtitle}</p>
  </header>

  <div class="v3-hero-grid" role="list">
    {heroDishes.map(({ item, image }, i) => (
      <a href="#menu" class={`v3-dish v3-dish-${i + 1}`} role="listitem">
        <Picture
          src={image.url}
          alt={image.alt}
          class="v3-dish-img"
          formats={['avif', 'webp']}
          widths={[320, 640, 900]}
          sizes="(max-width:900px) 50vw, 33vw"
          loading={i < 2 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />
        <div class="v3-dish-overlay"></div>
        <div class="v3-dish-body">
          <div class="v3-dish-name">{item.name}</div>
          <div class="v3-dish-price">${item.price}</div>
        </div>
      </a>
    ))}
  </div>

  <div class="v3-hero-grid-cta">
    <a href="#menu" class="v3-btn-primary">See the full menu &rarr;</a>
    <a href="#reservations" class="v3-btn-outline v3-btn-outline--dark">Reserve a table</a>
  </div>
</section>

<!-- ==================== INFO STRIP ==================== -->
<div class="v3-info-strip">
  <span class="v3-info-item">Grown within 30 miles</span>
  <span class="v3-info-sep">·</span>
  <span class="v3-info-item">Thu – Sun</span>
  <span class="v3-info-sep">·</span>
  <span class="v3-info-item">{restaurant.address.city}, {restaurant.address.state}</span>
</div>

<!-- ==================== MENU ==================== -->
<section class="v3-menu" id="menu">
  <div class="v3-menu-inner">
    <div class="v3-section-header sr">
      <span class="v3-label">This Week's Harvest</span>
      <h2 class="v3-section-title">The Menu</h2>
    </div>
    <p class="v3-menu-note sr">{restaurant.menu.note}</p>

    {restaurant.menu.categories.map((cat) => (
      <div class="v3-menu-cat sr">
        <h3 class="v3-cat-name">{cat.name}</h3>
        <div class="v3-cat-rule"></div>
        <div class="v3-items-grid">
          {cat.items.map((item) => (
            <div class="v3-item-card">
              <div class="v3-item-top">
                <span class="v3-item-name">{item.name}</span>
                <span class="v3-item-price">{item.price}</span>
              </div>
              {item.description && (
                <p class="v3-item-desc">{item.description}</p>
              )}
              {item.dietary && item.dietary.length > 0 && (
                <div class="v3-item-dietary">
                  {item.dietary.map((d) => (
                    <span class="v3-dietary-badge">{dietaryMap[d] ?? d}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="v3-dietary-key sr">
      {restaurant.menu.dietaryKey.map((k) => (
        <span class="v3-key-item">
          <span class="v3-dietary-badge">{k.symbol}</span>
          <span class="v3-key-label">{k.label}</span>
        </span>
      ))}
    </div>
  </div>
</section>

<!-- ==================== GALLERY ==================== -->
<section class="v3-gallery" id="gallery">
  <div class="v3-gallery-inner">
    <div class="v3-section-header sr">
      <span class="v3-label">Take a look around</span>
      <h2 class="v3-section-title">The Farm &amp; Kitchen</h2>
    </div>
    <div class="v3-gallery-grid">
      {restaurant.gallery.map((img, i) => (
        <div class={`v3-gallery-item${[1,3,5].includes(i) ? ' v3-gallery-tilt-' + (i % 2 === 1 ? 'left' : 'right') : ''}`}>
          <Picture
            src={img.url}
            alt={img.alt}
            class="v3-gallery-img"
            formats={['avif', 'webp']}
            widths={[320, 640, 1024]}
            sizes="(max-width:768px) 100vw, 33vw"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== ABOUT ==================== -->
<section class="v3-about" id="about">
  <div class="v3-about-inner">
    <div class="v3-about-text sr">
      <span class="v3-label">Our Story</span>
      <h2 class="v3-about-h2">{restaurant.about.headline}</h2>
      <blockquote class="v3-about-quote">
        "Connelly Farm has been in the family since 1962."
      </blockquote>
      {restaurant.about.story.split('\n\n').map((para) => (
        <p class="v3-about-para">{para}</p>
      ))}
    </div>
    <div class="v3-about-chef sr">
      <div class="v3-chef-photo-wrap">
        <Picture
          src={restaurant.about.chef.photo}
          alt={restaurant.about.chef.photoAlt}
          class="v3-chef-photo"
          formats={['avif', 'webp']}
          widths={[200, 400, 600]}
          sizes="200px"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="v3-chef-info">
        <span class="v3-chef-name">{restaurant.about.chef.name}</span>
        <span class="v3-chef-title">{restaurant.about.chef.title}</span>
        <p class="v3-chef-bio">{restaurant.about.chef.bio}</p>
      </div>
    </div>
  </div>
</section>

<!-- ==================== PURVEYORS (uniquify) ==================== -->
<section class="v3-purveyors" aria-label="Our farms and purveyors">
  <div class="v3-purveyors-inner sr">
    <div class="v3-purveyors-head">
      <span class="v3-purveyors-eyebrow">Where it all comes from</span>
      <h2 class="v3-purveyors-h2">From these woods, these fields, these barns</h2>
      <p class="v3-purveyors-sub">
        Every plate at Hen &amp; Hearth begins in a place we know by name. Here are
        the people whose work shows up on your table this week.
      </p>
    </div>
    <div class="v3-purveyors-grid">
      <article class="v3-purveyor-card">
        <span class="v3-purveyor-tag">Vegetables</span>
        <h3 class="v3-purveyor-name">Connelly Farm</h3>
        <p class="v3-purveyor-place">Our family acres</p>
        <p class="v3-purveyor-distance">0.4 miles · Woodstock, VT</p>
        <p class="v3-purveyor-supplies">
          Heirloom squash, Sungold tomatoes, salt-frost spinach, the herb garden
          out the kitchen door.
        </p>
      </article>
      <article class="v3-purveyor-card">
        <span class="v3-purveyor-tag">Cheese &amp; Dairy</span>
        <h3 class="v3-purveyor-name">Sugar Brook Creamery</h3>
        <p class="v3-purveyor-place">Marian &amp; Roy Tibbetts</p>
        <p class="v3-purveyor-distance">6 miles · Pomfret, VT</p>
        <p class="v3-purveyor-supplies">
          Raw-milk cheddar aged in their barn, cultured butter, the morning's
          buttermilk for our biscuits.
        </p>
      </article>
      <article class="v3-purveyor-card">
        <span class="v3-purveyor-tag">Meat</span>
        <h3 class="v3-purveyor-name">Hidden Pasture Farm</h3>
        <p class="v3-purveyor-place">The Whitcomb brothers</p>
        <p class="v3-purveyor-distance">11 miles · Barnard, VT</p>
        <p class="v3-purveyor-supplies">
          Pasture-raised pork, dry-aged beef from their woodlot herd, Sunday
          chickens for our hearth roast.
        </p>
      </article>
      <article class="v3-purveyor-card">
        <span class="v3-purveyor-tag">Bread &amp; Grain</span>
        <h3 class="v3-purveyor-name">Red Hen Baking</h3>
        <p class="v3-purveyor-place">Randy George</p>
        <p class="v3-purveyor-distance">38 miles · Middlesex, VT</p>
        <p class="v3-purveyor-supplies">
          Hearth loaves and the pan loaves we tear for stuffing. Vermont-grown
          wheat, milled fresh, baked overnight.
        </p>
      </article>
      <article class="v3-purveyor-card">
        <span class="v3-purveyor-tag">Cider &amp; Orchard</span>
        <h3 class="v3-purveyor-name">Champlain Orchards</h3>
        <p class="v3-purveyor-place">Bill &amp; Andrea Suhr</p>
        <p class="v3-purveyor-distance">62 miles · Shoreham, VT</p>
        <p class="v3-purveyor-supplies">
          Heirloom apples for tarts, ice cider for the cellar, the still cider
          we cook our pork shoulder in.
        </p>
      </article>
      <article class="v3-purveyor-card">
        <span class="v3-purveyor-tag">Maple &amp; Honey</span>
        <h3 class="v3-purveyor-name">Bragg Farm Sugarhouse</h3>
        <p class="v3-purveyor-place">Doug Bragg</p>
        <p class="v3-purveyor-distance">29 miles · East Montpelier, VT</p>
        <p class="v3-purveyor-supplies">
          Wood-fired maple, Grade A dark robust. The honey too — from the hives
          above the sugarhouse.
        </p>
      </article>
    </div>
    <p class="v3-purveyors-note">Thank you. — Birdie &amp; the kitchen</p>
  </div>
</section>

<!-- ==================== RESERVATIONS ==================== -->
<section class="v3-reservations" id="reservations">
  <div class="v3-reservations-inner sr">
    <h2 class="v3-res-h2"><em>Reserve Your Seat</em></h2>
    <p class="v3-res-sub">We write the menu after we walk the farm</p>
    <form class="v3-res-form" onsubmit="return false;">
      <div class="v3-res-row">
        <input type="text" placeholder="Your Name" class="v3-res-input" required />
        <input type="email" placeholder="Email Address" class="v3-res-input" required />
      </div>
      <div class="v3-res-row">
        <input type="tel" placeholder="Phone Number" class="v3-res-input" />
        <input type="number" placeholder="Party Size" min="1" max="20" class="v3-res-input" required />
      </div>
      <div class="v3-res-row">
        <input type="date" class="v3-res-input" required />
        <select class="v3-res-input v3-res-select">
          <option value="" disabled selected>Preferred Time</option>
          <option>5:00 PM</option>
          <option>5:30 PM</option>
          <option>6:00 PM</option>
          <option>6:30 PM</option>
          <option>7:00 PM</option>
          <option>7:30 PM</option>
          <option>8:00 PM</option>
          <option>8:30 PM</option>
          <option>9:00 PM</option>
        </select>
      </div>
      <textarea class="v3-res-input v3-res-textarea" placeholder="Special requests, dietary notes, occasion..." rows="3"></textarea>
      <button type="submit" class="v3-res-submit">Request Reservation</button>
    </form>
    <p class="v3-res-phone">
      Or call us: <a href={`tel:${restaurant.phone}`}>{restaurant.phone}</a>
    </p>
  </div>
</section>

<!-- ==================== CONTACT ==================== -->
<section class="v3-contact" id="contact">
  <div class="v3-contact-inner">
    <div class="v3-contact-info sr">
      <span class="v3-label">Find Us</span>
      <h2 class="v3-contact-h2">Come Visit</h2>

      <div class="v3-contact-block">
        <span class="v3-contact-subhead">Address</span>
        <p class="v3-contact-text">
          {restaurant.address.street}<br />
          {restaurant.address.city}, {restaurant.address.state} {restaurant.address.zip}
        </p>
        <a href={restaurant.mapDirectionsUrl} class="v3-contact-link" target="_blank" rel="noopener">Get Directions &rarr;</a>
      </div>

      <div class="v3-contact-block">
        <span class="v3-contact-subhead">Hours</span>
        <ul class="v3-hours-list">
          {restaurant.hours.map((h) => (
            <li class={`v3-hours-item${h.open === null ? ' v3-hours-closed' : ''}`}>
              <span class="v3-hours-day">{h.day}</span>
              <span class="v3-hours-time">{h.open ? `${h.open} – ${h.close}` : 'Closed'}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="v3-contact-block">
        <span class="v3-contact-subhead">Contact</span>
        <p class="v3-contact-text">
          <a href={`tel:${restaurant.phone}`} class="v3-contact-link">{restaurant.phone}</a><br />
          <a href={`mailto:${restaurant.email}`} class="v3-contact-link">{restaurant.email}</a>
        </p>
      </div>
    </div>

    <div class="v3-contact-map sr">
      <iframe
        src={restaurant.mapEmbedUrl}
        width="100%"
        height="440"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Hen &amp; Hearth location map"
        class="v3-map-iframe"
      ></iframe>
    </div>
  </div>
</section>

<!-- ==================== FOOTER ==================== -->
<footer class="v3-footer">
  <div class="v3-footer-inner">
    <div class="v3-footer-top">
      <div class="v3-footer-brand">
        <span class="v3-footer-logo"><em>Hen &amp; Hearth</em></span>
        <p class="v3-footer-tagline">Farm-to-Table · Woodstock, Vermont</p>
        <div class="v3-footer-social">
          {restaurant.social.instagram && (
            <a href={restaurant.social.instagram} class="v3-footer-social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
          {restaurant.social.facebook && (
            <a href={restaurant.social.facebook} class="v3-footer-social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {restaurant.social.yelp && (
            <a href={restaurant.social.yelp} class="v3-footer-social-link" target="_blank" rel="noopener" aria-label="Yelp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.73-.8-1.176-1.63L16.85 8.5c.558-.835 1.8-.518 1.894.482l.504 4.916c.02.18.008.35-.088.696zm-5.54 3.61l4.286 2.807c.826.54.63 1.833-.322 2.07l-4.814 1.2c-.956.237-1.673-.716-1.286-1.617l1.304-3.044a1.05 1.05 0 011.832-.416zm-3.74-8.625L9.84 2.695c-.347-.922.47-1.85 1.422-1.647l4.862 1.055c.948.205 1.17 1.495.337 2.007L12.3 6.762a1.05 1.05 0 01-1.42-.183zm-4.685 8.19L1.97 14.6c-.864-.432-.769-1.678.152-1.979l4.752-1.565c.924-.305 1.73.648 1.31 1.521l-1.8 3.558a1.05 1.05 0 01-1.437.434zm-.357-5.55l-4.862-.98C.01 9.035.03 7.753.935 7.47l4.77-1.47c.908-.28 1.673.657 1.29 1.523L5.47 11.02a1.05 1.05 0 01-1.635.198z"/></svg>
            </a>
          )}
        </div>
      </div>
      <div class="v3-footer-nav">
        <span class="v3-footer-col-head">Navigate</span>
        <ul class="v3-footer-links">
          <li><a href="#menu" class="v3-footer-link">Menu</a></li>
          <li><a href="#gallery" class="v3-footer-link">Gallery</a></li>
          <li><a href="#about" class="v3-footer-link">Our Story</a></li>
          <li><a href="#reservations" class="v3-footer-link">Reserve</a></li>
          <li><a href="#contact" class="v3-footer-link">Visit Us</a></li>
        </ul>
      </div>
      <div class="v3-footer-hours-col">
        <span class="v3-footer-col-head">The Weekly Dispatch</span>
        <p class="v3-footer-dispatch-blurb">
          A short Sunday note — what's coming in from the farms, what's on the
          board this week, who's playing the back room.
        </p>
        <form class="v3-footer-dispatch-form" onsubmit="return false;" aria-label="Subscribe to weekly dispatch">
          <input
            type="email"
            placeholder="your@email.com"
            class="v3-footer-dispatch-input"
            aria-label="Email address"
            required
          />
          <button type="submit" class="v3-footer-dispatch-btn">Subscribe</button>
        </form>
        <span class="v3-footer-dispatch-hint">No spam. Unsubscribe anytime.</span>
      </div>
    </div>
    <div class="v3-footer-bottom">
      <span class="v3-footer-copy">&copy; {new Date().getFullYear()} Hen &amp; Hearth. All rights reserved.</span>
      <span class="v3-footer-location">Woodstock, Vermont</span>
    </div>
    <p class="v3-footer-attrib">
      Built by <a href="https://dcrader.dev" target="_blank" rel="noopener">Donovan Crader &middot; dcrader.dev</a>
    </p>
  </div>
</footer>

<style>
  /* =============================================
     CSS CUSTOM PROPERTIES
  ============================================= */
  :root {
    --v3-parchment: #F5F0E5;
    --v3-cream: #EDE5D0;
    --v3-green: #2D5016;
    --v3-green-dark: #1A3009;
    --v3-green-light: #3D6B1E;
    --v3-brown: #7A5230;
    --v3-butter: #D4A843;
    --v3-dark: #1A0E04;
    --v3-text: #2A1A0A;
    --v3-muted: #8A7860;
    --v3-border: rgba(42,26,10,0.15);
    --v3-font-display: 'Fraunces', Georgia, serif;
    --v3-font-hand: 'Caveat', cursive;
    --v3-font-body: 'Source Sans 3', system-ui, sans-serif;
  }

  /* Reset within scope */
  .v3-nav,
  .v3-hero,
  .v3-info-strip,
  .v3-menu,
  .v3-gallery,
  .v3-about,
  .v3-reservations,
  .v3-contact,
  .v3-footer {
    box-sizing: border-box;
  }

  *,
  *::before,
  *::after {
    box-sizing: inherit;
  }

  /* Scroll-reveal disabled: content visible immediately. */
  .sr, .sr-visible {
    opacity: 1;
    transform: none;
    transition: none;
  }

  /* =============================================
     NAV
  ============================================= */
  .v3-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: var(--v3-green);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    height: 64px;
  }

  .v3-nav-logo {
    font-family: var(--v3-font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .v3-hamburger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 6px;
    outline: none;
  }

  .v3-hamburger span {
    display: block;
    width: 26px;
    height: 2.5px;
    background: #ffffff;
    border-radius: 99px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* Nav overlay */
  .v3-nav-overlay {
    position: fixed;
    inset: 0;
    background: var(--v3-green);
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .v3-nav-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .v3-nav-close {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    background: none;
    border: none;
    color: #ffffff;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    font-family: var(--v3-font-body);
  }

  .v3-overlay-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .v3-overlay-link {
    font-family: var(--v3-font-display);
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400;
    color: #ffffff;
    text-decoration: none;
    line-height: 1.2;
    transition: opacity 0.2s ease;
    letter-spacing: -0.01em;
  }

  .v3-overlay-link:hover {
    opacity: 0.65;
  }

  .v3-overlay-est {
    position: absolute;
    bottom: 2.5rem;
    font-family: var(--v3-font-hand);
    font-size: 1.2rem;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.05em;
  }

  /* =============================================
     HERO — MENU-LED GRID
  ============================================= */
  .v3-hero {
    padding-top: 64px;
    background: var(--v3-cream, #F6EFE2);
  }

  .v3-hero--menu {
    display: block;
    min-height: 0;
    padding: calc(64px + 3rem) 2rem 4rem;
  }

  .v3-hero-grid-header {
    max-width: 1120px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .v3-hero-eyebrow {
    font-family: var(--v3-font-hand);
    font-size: 1.1rem;
    color: var(--v3-green);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    display: block;
  }

  .v3-hero-grid-h1 {
    font-family: var(--v3-font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 600;
    color: var(--v3-dark, #2A1A0A);
    line-height: 1.02;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }
  .v3-hero-grid-h1 em {
    font-weight: 400;
    font-style: italic;
    color: var(--v3-green);
  }

  .v3-hero-grid-sub {
    font-family: var(--v3-font-body);
    font-size: 1rem;
    color: rgba(42,26,10,0.75);
    max-width: 36rem;
    line-height: 1.6;
    margin: 0 auto;
  }

  .v3-hero-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 240px);
    gap: 0.85rem;
  }
  .v3-dish {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    display: block;
    text-decoration: none;
    color: #fff;
    background: var(--v3-dark, #2A1A0A);
  }
  .v3-dish-1 { grid-column: span 2; grid-row: span 2; }
  .v3-dish-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .v3-dish:hover .v3-dish-img { transform: scale(1.04); }
  .v3-dish-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.20) 55%, rgba(0,0,0,0.05) 100%);
  }
  .v3-dish-body {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.9rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .v3-dish-name {
    font-family: var(--v3-font-display);
    font-weight: 500;
    font-size: 1.05rem;
    line-height: 1.2;
  }
  .v3-dish-1 .v3-dish-name { font-size: 1.5rem; }
  .v3-dish-price {
    font-family: var(--v3-font-hand);
    font-size: 1.3rem;
    color: var(--v3-butter);
    white-space: nowrap;
  }

  .v3-hero-grid-cta {
    max-width: 1200px;
    margin: 2.5rem auto 0;
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .v3-btn-outline--dark {
    color: var(--v3-dark, #2A1A0A);
    border-color: rgba(42,26,10,0.35);
  }
  .v3-btn-outline--dark:hover {
    border-color: var(--v3-dark, #2A1A0A);
    background: rgba(42,26,10,0.06);
  }

  /* Legacy hero stubs (no longer used in markup) */
  .v3-hero-left, .v3-hero-right, .v3-hero-img,
  .v3-hero-overlay, .v3-hero-h1, .v3-hero-sub, .v3-hero-btns { /* unused */ }

  .v3-btn-primary {
    background: var(--v3-butter);
    color: var(--v3-dark);
    font-family: var(--v3-font-body);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .v3-btn-primary:hover {
    background: #e6b84d;
    transform: translateY(-1px);
  }

  .v3-btn-outline {
    background: transparent;
    color: #ffffff;
    font-family: var(--v3-font-body);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    border: 1.5px solid rgba(255,255,255,0.6);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .v3-btn-outline:hover {
    border-color: #ffffff;
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }

  /* (Legacy split-hero CSS removed — replaced by .v3-hero-grid above.) */

  /* =============================================
     INFO STRIP
  ============================================= */
  .v3-info-strip {
    background: var(--v3-parchment);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    border-bottom: 1px solid var(--v3-border);
  }

  .v3-info-item {
    font-family: var(--v3-font-hand);
    font-size: 1rem;
    color: var(--v3-brown);
    letter-spacing: 0.03em;
  }

  .v3-info-sep {
    font-family: var(--v3-font-hand);
    font-size: 1rem;
    color: var(--v3-muted);
  }

  /* =============================================
     SHARED SECTION HEADER
  ============================================= */
  .v3-section-header {
    text-align: center;
    margin-bottom: 1rem;
  }

  .v3-label {
    display: block;
    font-family: var(--v3-font-hand);
    font-size: 1.2rem;
    color: var(--v3-green);
    letter-spacing: 0.04em;
    margin-bottom: 0.4rem;
  }

  .v3-section-title {
    font-family: var(--v3-font-display);
    font-size: clamp(2.8rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--v3-dark);
    margin: 0;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  /* =============================================
     MENU
  ============================================= */
  .v3-menu {
    background: var(--v3-parchment);
    padding: 7rem 2.5rem;
  }

  .v3-menu-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .v3-menu-note {
    font-family: var(--v3-font-hand);
    font-size: 1rem;
    color: var(--v3-brown);
    text-align: center;
    margin: 0.75rem 0 3rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .v3-menu-cat {
    margin-bottom: 3.5rem;
  }

  .v3-cat-name {
    font-family: var(--v3-font-hand);
    font-size: 1.6rem;
    color: var(--v3-green);
    margin: 0 0 0.5rem 0;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .v3-cat-rule {
    height: 3px;
    background: var(--v3-green);
    border-radius: 2px;
    margin-bottom: 1.25rem;
    opacity: 0.35;
  }

  .v3-items-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }

  .v3-item-card {
    background: var(--v3-cream);
    border: 1px solid rgba(42,26,10,0.12);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    transition: box-shadow 0.2s ease;
  }

  .v3-item-card:hover {
    box-shadow: 0 3px 16px rgba(42,26,10,0.1);
  }

  .v3-item-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .v3-item-name {
    font-family: var(--v3-font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--v3-dark);
    line-height: 1.2;
  }

  .v3-item-price {
    font-family: var(--v3-font-display);
    font-style: italic;
    font-size: 1rem;
    color: var(--v3-brown);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .v3-item-desc {
    font-family: var(--v3-font-body);
    font-size: 0.8rem;
    color: var(--v3-muted);
    line-height: 1.55;
    margin: 0 0 0.5rem 0;
  }

  .v3-item-dietary {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .v3-dietary-badge {
    font-family: var(--v3-font-body);
    font-size: 0.68rem;
    font-weight: 600;
    background: var(--v3-butter);
    color: var(--v3-dark);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .v3-dietary-key {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--v3-border);
  }

  .v3-key-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .v3-key-label {
    font-family: var(--v3-font-body);
    font-size: 0.8rem;
    color: var(--v3-muted);
  }

  /* =============================================
     GALLERY
  ============================================= */
  .v3-gallery {
    background: var(--v3-cream);
    padding: 7rem 2.5rem;
  }

  .v3-gallery-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .v3-gallery-grid {
    columns: 3;
    column-gap: 1rem;
    margin-top: 3rem;
  }

  .v3-gallery-item {
    break-inside: avoid;
    margin-bottom: 1rem;
    overflow: hidden;
    border-radius: 3px;
    border: 2px solid var(--v3-cream);
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .v3-gallery-item:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 24px rgba(0,0,0,0.14);
  }

  .v3-gallery-tilt-left {
    transform: rotate(-1.5deg);
  }

  .v3-gallery-tilt-left:hover {
    transform: rotate(-1.5deg) scale(1.02);
  }

  .v3-gallery-tilt-right {
    transform: rotate(1deg);
  }

  .v3-gallery-tilt-right:hover {
    transform: rotate(1deg) scale(1.02);
  }

  .v3-gallery-img {
    display: block;
    width: 100%;
    height: auto;
    filter: saturate(0.9) brightness(1.0);
    transition: filter 0.3s ease;
  }

  .v3-gallery-item:hover .v3-gallery-img {
    filter: saturate(1.0) brightness(1.02);
  }

  /* =============================================
     ABOUT
  ============================================= */
  .v3-about {
    background: var(--v3-parchment);
    padding: 7rem 2.5rem;
  }

  .v3-about-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 5rem;
    align-items: start;
  }

  .v3-about-h2 {
    font-family: var(--v3-font-display);
    font-size: clamp(2.4rem, 4vw, 3.5rem);
    font-weight: 600;
    font-style: normal;
    color: var(--v3-dark);
    margin: 0.5rem 0 1.25rem 0;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .v3-about-quote {
    font-family: var(--v3-font-hand);
    font-size: 1.4rem;
    color: var(--v3-brown);
    font-style: italic;
    border-left: 3px solid var(--v3-butter);
    padding-left: 1.25rem;
    margin: 0 0 1.75rem 0;
    line-height: 1.5;
  }

  .v3-about-para {
    font-family: var(--v3-font-body);
    font-size: 0.92rem;
    color: var(--v3-muted);
    line-height: 1.85;
    margin: 0 0 1rem 0;
  }

  .v3-about-chef {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .v3-chef-photo-wrap {
    width: 320px;
    height: 380px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--v3-cream);
    box-shadow: 0 6px 28px rgba(42,26,10,0.15);
    flex-shrink: 0;
  }

  .v3-chef-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .v3-chef-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .v3-chef-name {
    font-family: var(--v3-font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--v3-dark);
    display: block;
  }

  .v3-chef-title {
    font-family: var(--v3-font-hand);
    font-size: 1rem;
    color: var(--v3-green);
    display: block;
    letter-spacing: 0.03em;
  }

  .v3-chef-bio {
    font-family: var(--v3-font-body);
    font-size: 0.82rem;
    font-style: italic;
    color: var(--v3-muted);
    line-height: 1.65;
    margin: 0.25rem 0 0;
    max-width: 260px;
  }

  /* =============================================
     PURVEYORS  (uniquify module — v3)
  ============================================= */
  .v3-purveyors {
    background: var(--v3-parchment);
    padding: 7rem 2.5rem;
    border-top: 1px solid var(--v3-border);
  }
  .v3-purveyors-inner {
    max-width: 68rem;
    margin: 0 auto;
  }
  .v3-purveyors-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .v3-purveyors-eyebrow {
    font-family: var(--v3-font-hand);
    color: var(--v3-brown);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .v3-purveyors-h2 {
    font-family: var(--v3-font-display);
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--v3-text);
    margin: 0 0 0.75rem;
    font-style: italic;
  }
  .v3-purveyors-sub {
    font-family: var(--v3-font-body);
    color: var(--v3-muted);
    max-width: 36rem;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.65;
  }
  .v3-purveyors-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .v3-purveyor-card {
    background: #fff;
    border: 1px solid var(--v3-border);
    padding: 2rem 1.75rem;
    position: relative;
  }
  .v3-purveyor-card::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px dashed rgba(122,82,48,0.25);
    pointer-events: none;
  }
  .v3-purveyor-tag {
    display: inline-block;
    background: var(--v3-butter);
    color: var(--v3-dark);
    font-family: var(--v3-font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    margin-bottom: 1.25rem;
  }
  .v3-purveyor-name {
    font-family: var(--v3-font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--v3-text);
    margin: 0 0 0.25rem;
  }
  .v3-purveyor-place {
    font-family: var(--v3-font-hand);
    font-size: 1.15rem;
    color: var(--v3-green);
    margin: 0 0 0.85rem;
  }
  .v3-purveyor-distance {
    font-family: var(--v3-font-body);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--v3-muted);
    margin: 0 0 0.85rem;
  }
  .v3-purveyor-supplies {
    font-family: var(--v3-font-body);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--v3-text);
    margin: 0;
  }
  .v3-purveyors-note {
    margin-top: 3rem;
    text-align: center;
    font-family: var(--v3-font-hand);
    font-size: 1.4rem;
    color: var(--v3-brown);
  }
  @media (max-width: 900px) {
    .v3-purveyors-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 600px) {
    .v3-purveyors { padding: 4rem 1.25rem; }
    .v3-purveyors-grid { grid-template-columns: 1fr; }
  }

  /* =============================================
     RESERVATIONS
  ============================================= */
  .v3-reservations {
    background: var(--v3-green);
    padding: 7rem 2.5rem;
  }

  .v3-reservations-inner {
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }

  .v3-res-h2 {
    font-family: var(--v3-font-display);
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.02em;
  }

  .v3-res-h2 em {
    font-style: italic;
  }

  .v3-res-sub {
    font-family: var(--v3-font-hand);
    font-size: 1.1rem;
    color: var(--v3-butter);
    margin: 0 0 2.5rem 0;
    display: block;
    letter-spacing: 0.02em;
  }

  .v3-res-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
  }

  .v3-res-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .v3-res-input {
    background: var(--v3-parchment);
    border: none;
    border-radius: 4px;
    padding: 0.875rem 1rem;
    font-family: var(--v3-font-body);
    font-size: 0.9rem;
    color: var(--v3-text);
    width: 100%;
    outline: none;
    transition: box-shadow 0.2s ease;
  }

  .v3-res-input:focus {
    box-shadow: 0 0 0 2px var(--v3-butter);
  }

  .v3-res-input::placeholder {
    color: var(--v3-muted);
  }

  .v3-res-select {
    appearance: none;
    cursor: pointer;
  }

  .v3-res-textarea {
    resize: vertical;
    min-height: 90px;
  }

  .v3-res-submit {
    background: var(--v3-butter);
    color: var(--v3-dark);
    border: none;
    border-radius: 4px;
    padding: 1rem 2rem;
    font-family: var(--v3-font-display);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    width: 100%;
    letter-spacing: 0.01em;
    transition: background 0.2s ease, transform 0.2s ease;
    margin-top: 0.25rem;
  }

  .v3-res-submit:hover {
    background: #e6b84d;
    transform: translateY(-1px);
  }

  .v3-res-phone {
    font-family: var(--v3-font-hand);
    font-size: 1.05rem;
    color: rgba(255,255,255,0.7);
    margin: 1.75rem 0 0;
  }

  .v3-res-phone a {
    color: rgba(255,255,255,0.9);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* =============================================
     CONTACT
  ============================================= */
  .v3-contact {
    background: var(--v3-parchment);
    padding: 7rem 2.5rem;
  }

