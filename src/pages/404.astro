---
// Branded 404 — mirrors the dark-elegant aesthetic of index.astro
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The page you're looking for isn't on the menu." />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
      rel="stylesheet"
    />
    <title>404 — Page Not Found</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        min-height: 100vh;
        background: #080706;
        color: #EDE8DE;
        font-family: 'DM Sans', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
      }

      /* Animated background grain (matches index.astro) */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 0;
      }

      .glow {
        position: absolute;
        top: -160px;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 600px;
        max-width: 100vw;
        background: radial-gradient(ellipse at center, rgba(201,168,76,0.08) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: clamp(4rem, 10vw, 8rem) 1.5rem;
        max-width: 44rem;
        margin: 0 auto;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.48em;
        text-transform: uppercase;
        color: #C9A84C;
        margin-bottom: 1.75rem;
        opacity: 0;
        animation: fadeInDown 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s forwards;
      }
      .eyebrow::before, .eyebrow::after {
        content: '';
        display: block;
        width: 2rem;
        height: 1px;
        background: currentColor;
        opacity: 0.5;
      }

      .code {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 400;
        font-size: clamp(6rem, 18vw, 12rem);
        line-height: 1;
        color: #C9A84C;
        letter-spacing: -0.02em;
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeInDown 0.8s cubic-bezier(0.22,1,0.36,1) 0.18s forwards;
      }

      h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 400;
        font-size: clamp(1.625rem, 3.5vw, 2.25rem);
        line-height: 1.15;
        color: #EDE8DE;
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeInDown 0.8s cubic-bezier(0.22,1,0.36,1) 0.3s forwards;
      }
      h1 em {
        font-style: italic;
        color: rgba(237,232,222,0.55);
      }

      .body-copy {
        font-size: 0.9375rem;
        line-height: 1.75;
        color: rgba(237,232,222,0.45);
        max-width: 30rem;
        margin: 0 auto 2.5rem;
        font-weight: 300;
        opacity: 0;
        animation: fadeInDown 0.8s cubic-bezier(0.22,1,0.36,1) 0.42s forwards;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.95rem 1.75rem;
        background: #C9A84C;
        color: #0B0A08;
        text-decoration: none;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        border-radius: 999px;
        transition: transform 0.25s cubic-bezier(0.22,1,0.36,1), background 0.25s, box-shadow 0.25s;
        box-shadow: 0 8px 30px -10px rgba(201,168,76,0.45);
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.22,1,0.36,1) 0.55s forwards;
      }
      .cta:hover {
        transform: translateY(-2px);
        background: #D7B85C;
        box-shadow: 0 12px 36px -10px rgba(201,168,76,0.6);
      }
      .cta svg { transition: transform 0.25s cubic-bezier(0.22,1,0.36,1); }
      .cta:hover svg { transform: translateX(3px); }

      footer {
        position: relative;
        z-index: 1;
        border-top: 1px solid rgba(237,232,222,0.06);
        padding: 2.25rem 1.5rem;
        text-align: center;
      }
      footer p {
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(237,232,222,0.16);
      }
      footer a { color: inherit; text-decoration: none; }
      footer a:hover { color: rgba(237,232,222,0.38); }

      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-16px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @media (prefers-reduced-motion: reduce) {
        .eyebrow, .code, h1, .body-copy, .cta { animation: none; opacity: 1; transform: none; }
      }
    </style>
  </head>
  <body>
    <div class="glow" aria-hidden="true"></div>

    <main>
      <p class="eyebrow">Off the Menu</p>
      <p class="code" aria-hidden="true">404</p>
      <h1>This table <em>isn't set.</em></h1>
      <p class="body-copy">
        The page you're looking for isn't on tonight's menu. Head back to the
        dining room and explore the templates instead.
      </p>
      <a href="/" class="cta">
        Back to home
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" />
        </svg>
      </a>
    </main>

    <footer>
      <p>Astro · Tailwind CSS v4 · Photos: Unsplash</p>
      <p>Built by <a href="https://dcrader.dev" target="_blank" rel="noopener">Donovan Crader · dcrader.dev</a></p>
    </footer>
  </body>
</html>
