---
import { restaurant } from '../data/restaurant';
---

<section
  id="reservations"
  class="section-padding relative overflow-hidden"
  style="background-color: #F5E8C8;"
  aria-labelledby="reservations-heading"
>
  <!-- Subtle background texture -->
  <div class="absolute inset-0 bg-grain opacity-30 pointer-events-none" aria-hidden="true"></div>

  <div class="container-narrow relative">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="section-label mb-4">Join Us</p>
      <h2 id="reservations-heading" class="section-title">Reserve a Table</h2>
      <div class="flex justify-center mt-5 mb-6">
        <div class="divider-gold"></div>
      </div>
      <p class="font-sans text-stone-600 text-sm max-w-sm mx-auto leading-relaxed">
        We hold reservations for 15 minutes past your booking time. For groups of 8 or more,
        please call us directly.
      </p>
    </div>

    {restaurant.openTableId ? (
      <!-- OpenTable embed — replace null with your real OpenTable restaurant ID -->
      <div class="flex justify-center">
        <div id="ot-widget-container" class="w-full max-w-lg bg-white p-8 shadow-sm">
          <script
            type="text/javascript"
            src={`https://www.opentable.com/widget/reservation/loader?rid=${restaurant.openTableId}&type=standard&theme=tall&color=1&dark=false&iframe=true&domain=com&lang=en-US&newtab=false&ot_source=Restaurant website`}
          ></script>
          <noscript>
            <a href={restaurant.social.yelp} target="_blank" rel="noopener">Reserve on Yelp</a>
          </noscript>
        </div>
      </div>
    ) : (
      <!-- Reservation request form — used when no OpenTable ID is set -->
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">

        <!-- Form -->
        <form
          id="reservation-form"
          class="lg:col-span-3 bg-white p-8 sm:p-10 shadow-sm"
          novalidate
          aria-label="Reservation request form"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <!-- Name -->
            <div class="sm:col-span-2">
              <label for="res-name" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Name <span class="text-terracotta" aria-hidden="true">*</span>
              </label>
              <input
                id="res-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                placeholder="Your full name"
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal placeholder:text-stone-300 focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="res-email" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Email <span class="text-terracotta" aria-hidden="true">*</span>
              </label>
              <input
                id="res-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal placeholder:text-stone-300 focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="res-phone" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Phone
              </label>
              <input
                id="res-phone"
                type="tel"
                name="phone"
                autocomplete="tel"
                placeholder="(619) 555-0000"
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal placeholder:text-stone-300 focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream"
              />
            </div>

            <!-- Date -->
            <div>
              <label for="res-date" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Date <span class="text-terracotta" aria-hidden="true">*</span>
              </label>
              <input
                id="res-date"
                type="date"
                name="date"
                required
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream"
              />
            </div>

            <!-- Time -->
            <div>
              <label for="res-time" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Preferred Time <span class="text-terracotta" aria-hidden="true">*</span>
              </label>
              <select
                id="res-time"
                name="time"
                required
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream appearance-none"
              >
                <option value="" disabled selected>Select a time</option>
                {['5:00 PM','5:30 PM','6:00 PM','6:30 PM','7:00 PM','7:30 PM','8:00 PM','8:30 PM','9:00 PM','9:30 PM'].map(t => (
                  <option value={t}>{t}</option>
                ))}
              </select>
            </div>

            <!-- Party size -->
            <div>
              <label for="res-party" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Party Size <span class="text-terracotta" aria-hidden="true">*</span>
              </label>
              <select
                id="res-party"
                name="party"
                required
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream appearance-none"
              >
                <option value="" disabled selected>Select</option>
                {[1,2,3,4,5,6,7].map(n => (
                  <option value={n}>{n} {n === 1 ? 'guest' : 'guests'}</option>
                ))}
                <option value="8+">8+ guests (call us)</option>
              </select>
            </div>

            <!-- Special requests -->
            <div class="sm:col-span-2">
              <label for="res-notes" class="block font-sans text-xs font-semibold tracking-[0.15em] uppercase text-stone-500 mb-2">
                Special Requests
              </label>
              <textarea
                id="res-notes"
                name="notes"
                rows="3"
                placeholder="Allergies, celebrations, seating preferences…"
                class="w-full px-4 py-3 border border-stone-200 font-sans text-sm text-charcoal placeholder:text-stone-300 focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 bg-cream resize-none"
              ></textarea>
            </div>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full btn-primary justify-center"
          >
            Request Reservation
          </button>

          <!-- Success message (hidden by default) -->
          <div id="res-success" class="hidden mt-4 p-4 bg-sage/10 border border-sage/30 text-sage font-sans text-sm text-center" role="alert" aria-live="polite">
            Thank you! We'll confirm your reservation within 2 hours.
          </div>
          <div id="res-error" class="hidden mt-4 p-4 bg-terracotta/10 border border-terracotta/30 text-terracotta font-sans text-sm text-center" role="alert" aria-live="polite">
            Something went wrong. Please call us at {restaurant.phone}.
          </div>
        </form>

        <!-- Info sidebar -->
        <aside class="lg:col-span-2 flex flex-col gap-6" aria-label="Reservation information">
          <!-- Call CTA -->
          <div class="bg-charcoal text-white p-7">
            <p class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-white/40 mb-3">
              Prefer to call?
            </p>
            <a
              href={`tel:${restaurant.phone.replace(/\D/g, '')}`}
              class="font-serif text-2xl text-white hover:text-gold transition-colors duration-200"
              aria-label={`Call ${restaurant.phone}`}
            >
              {restaurant.phone}
            </a>
            <p class="font-sans text-white/50 text-sm mt-2">
              Tue–Thu 4 PM · Fri–Sun 3 PM
            </p>
          </div>

          <!-- Policies -->
          <div class="space-y-4">
            {[
              { icon: 'M12 8v4l3 2M10 18a8 8 0 100-16 8 8 0 000 16', text: 'We hold tables for 15 minutes. Please call if you\'ll be late.' },
              { icon: 'M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0', text: 'Confirmation sent by email within 2 hours.' },
              { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0', text: 'Groups of 8+ please call for private dining inquiry.' },
            ].map(item => (
              <div class="flex gap-3 items-start">
                <svg class="w-4 h-4 text-terracotta mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={item.icon} />
                </svg>
                <p class="font-sans text-sm text-stone-500 leading-relaxed">{item.text}</p>
              </div>
            ))}
          </div>
        </aside>
      </div>
    )}
  </div>
</section>

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement | null;
  if (form) {
    // Set min date to today
    const dateInput = document.getElementById('res-date') as HTMLInputElement;
    if (dateInput) {
      const today = new Date().toISOString().split('T')[0];
      dateInput.min = today;
    }

    form.addEventListener('submit', async e => {
      e.preventDefault();
      const success = document.getElementById('res-success')!;
      const error = document.getElementById('res-error')!;

      // Demo: just show success. In production, POST to your endpoint or Formspree.
      success.classList.remove('hidden');
      error.classList.add('hidden');
      form.reset();
    });
  }
</script>
