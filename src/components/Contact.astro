---
import { restaurant } from '../data/restaurant';
---

<section id="contact" class="section-padding bg-stone-100" aria-labelledby="contact-heading">
  <div class="container-wide">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="section-label mb-4">Find Us</p>
      <h2 id="contact-heading" class="section-title">Visit Bella Sole</h2>
      <div class="flex justify-center mt-5">
        <div class="divider-gold"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 shadow-sm overflow-hidden">

      <!-- Map -->
      <div class="lg:col-span-3 h-80 lg:h-full min-h-[320px] bg-stone-200 relative">
        <iframe
          title={`Map showing ${restaurant.name} location at ${restaurant.address.full}`}
          src={restaurant.mapEmbedUrl}
          class="w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

      <!-- Contact info -->
      <div class="lg:col-span-2 bg-white p-8 sm:p-10 lg:p-12 flex flex-col gap-8">

        <!-- Address -->
        <div>
          <p class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-stone-400 mb-3">
            Address
          </p>
          <address class="not-italic">
            <p class="font-serif text-charcoal text-lg leading-snug">{restaurant.address.street}</p>
            <p class="font-serif text-charcoal text-lg leading-snug">{restaurant.address.city}, {restaurant.address.state} {restaurant.address.zip}</p>
          </address>
          <a
            href={restaurant.mapDirectionsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 mt-3 font-sans text-xs font-semibold tracking-[0.15em] uppercase text-terracotta hover:text-terracotta-dark transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:ring-offset-2"
          >
            Get Directions
            <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
        </div>

        <!-- Hours -->
        <div>
          <p class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-stone-400 mb-3">
            Hours
          </p>
          <ul class="space-y-1.5">
            {restaurant.hours.map(h => {
              const isToday = h.day === ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][new Date().getDay()];
              return (
                <li class={`flex justify-between gap-4 font-sans text-sm ${isToday ? 'font-semibold text-charcoal' : 'text-stone-500'}`}>
                  <span class="flex items-center gap-2">
                    {isToday && <span class="w-1.5 h-1.5 rounded-full bg-terracotta flex-shrink-0" aria-label="Today" role="img"></span>}
                    <span>{h.day}</span>
                  </span>
                  <span>
                    {h.open ? `${h.open} – ${h.close}` : 'Closed'}
                  </span>
                </li>
              );
            })}
          </ul>
        </div>

        <!-- Phone & email -->
        <div class="space-y-3">
          <a
            href={`tel:${restaurant.phone.replace(/\D/g, '')}`}
            class="flex items-center gap-3 font-sans text-sm text-stone-600 hover:text-charcoal transition-colors duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2"
          >
            <span class="w-8 h-8 rounded-full bg-stone-100 group-hover:bg-stone-200 flex items-center justify-center transition-colors duration-200 flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-terracotta" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 2.5C2 2.5 4 1 5.5 2.5S5 5.5 6.5 7s2.5-.5 4 1-1 3.5-1 3.5-3.5 1.5-6.5-1.5S2 2.5 2 2.5z" />
              </svg>
            </span>
            {restaurant.phone}
          </a>
          <a
            href={`mailto:${restaurant.email}`}
            class="flex items-center gap-3 font-sans text-sm text-stone-600 hover:text-charcoal transition-colors duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-charcoal focus-visible:ring-offset-2"
          >
            <span class="w-8 h-8 rounded-full bg-stone-100 group-hover:bg-stone-200 flex items-center justify-center transition-colors duration-200 flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-terracotta" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="1" y="3" width="14" height="10" rx="1.5" />
                <path d="M1 4l7 5 7-5" />
              </svg>
            </span>
            {restaurant.email}
          </a>
        </div>

        <!-- Social -->
        <div>
          <p class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-stone-400 mb-3">
            Follow Along
          </p>
          <div class="flex gap-3">
            <a
              href={restaurant.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full border border-stone-200 flex items-center justify-center text-stone-400 hover:text-terracotta hover:border-terracotta transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:ring-offset-2"
              aria-label="Follow on Instagram"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none" />
              </svg>
            </a>
            <a
              href={restaurant.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full border border-stone-200 flex items-center justify-center text-stone-400 hover:text-terracotta hover:border-terracotta transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:ring-offset-2"
              aria-label="Follow on Facebook"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
              </svg>
            </a>
            <a
              href={restaurant.social.yelp}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full border border-stone-200 flex items-center justify-center text-stone-400 hover:text-terracotta hover:border-terracotta transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:ring-offset-2"
              aria-label="View on Yelp"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.87 14.2l-4.64-1.16a.76.76 0 00-.9.9l1.2 4.64c.15.6.9.78 1.35.36l3.46-3.46c.45-.42.12-1.14-.47-1.28zm-7.57 2.6l-1.5 4.45c-.2.6.3 1.18.93 1.08l4.73-.75c.63-.1.87-.88.44-1.35l-3.25-3.7a.76.76 0 00-1.35.27zM10.1 3.44l-.75 4.73c-.1.63.45 1.13 1.08.93l4.45-1.5a.76.76 0 00.27-1.35L11.45 3a.76.76 0 00-1.35.44zm-2 8.27L3.14 9.3c-.47-.47-1.25-.23-1.35.44l-.75 4.73c-.1.63.45 1.13 1.08.93l4.63-1.5a.76.76 0 00.36-1.2zM3.13 5.4L6.6 8.87c.45.45 1.2.27 1.35-.44l.75-4.73c.1-.63-.45-1.13-1.08-.93L3.9 4.02c-.63.2-.87.98-.77 1.38z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
