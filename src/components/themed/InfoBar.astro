---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;

const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const todayName = days[new Date().getDay()];
const todayHours = restaurant.hours.find(h => h.day === todayName);
const todayLabel = todayHours?.open ? `${todayHours.open} – ${todayHours.close}` : 'Closed today';
---

<section id="info" aria-label="Location and hours" style="background-color: var(--t-dark);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x"
      style="border-color: rgba(255,255,255,0.1);"
    >
      <!-- Address -->
      <a href={restaurant.mapDirectionsUrl} target="_blank" rel="noopener noreferrer"
        class="group flex items-center gap-4 py-5 sm:py-6 sm:pr-8 px-2 sm:px-0 transition-colors duration-200 hover:bg-white/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset"
        style={`--ring-color: var(--t-accent);`}
        aria-label={`Get directions to ${restaurant.address.full}`}
      >
        <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center transition-colors duration-200"
          style="background-color: rgba(var(--t-accent), 0.15);"
        >
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--t-accent);">
            <path d="M10 2C7.24 2 5 4.24 5 7c0 4 5 11 5 11s5-7 5-11c0-2.76-2.24-5-5-5z" />
            <circle cx="10" cy="7" r="2" />
          </svg>
        </div>
        <div>
          <p class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase mb-0.5 opacity-40" style="color: var(--t-text-light); font-family: var(--t-body-font);">Location</p>
          <p class="text-sm font-medium opacity-90 group-hover:opacity-100 transition-opacity" style="color: var(--t-text-light); font-family: var(--t-body-font);">{restaurant.address.street}</p>
          <p class="text-xs opacity-50" style="color: var(--t-text-light); font-family: var(--t-body-font);">{restaurant.address.city}, {restaurant.address.state} {restaurant.address.zip}</p>
        </div>
      </a>

      <!-- Hours -->
      <a href="#contact"
        class="group flex items-center gap-4 py-5 sm:py-6 sm:px-8 px-2 transition-colors duration-200 hover:bg-white/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset"
        aria-label="View full hours"
      >
        <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center transition-colors duration-200" style="background-color: rgba(255,255,255,0.08);">
          <svg class="w-4 h-4 opacity-70" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true" style="color: var(--t-accent);">
            <circle cx="10" cy="10" r="8" /><path d="M10 6v4l3 2" />
          </svg>
        </div>
        <div>
          <p class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase mb-0.5 opacity-40" style="color: var(--t-text-light); font-family: var(--t-body-font);">Hours — {todayName}</p>
          <p class="text-sm font-medium opacity-90 group-hover:opacity-100 transition-opacity" style="color: var(--t-text-light); font-family: var(--t-body-font);">{todayLabel}</p>
          <p class="text-xs opacity-50" style="color: var(--t-text-light); font-family: var(--t-body-font);">See full schedule below</p>
        </div>
      </a>

      <!-- Phone -->
      <a href={`tel:${restaurant.phone.replace(/\D/g, '')}`}
        class="group flex items-center gap-4 py-5 sm:py-6 sm:pl-8 px-2 sm:px-0 transition-colors duration-200 hover:bg-white/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset"
        aria-label={`Call ${restaurant.phone}`}
      >
        <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center" style="background-color: rgba(255,255,255,0.08);">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--t-accent);">
            <path d="M3 3.5C3 3.5 5 1 7 3s1 4 3 5 3-1 5 1-1.5 4-1.5 4S8 14 4 10 3 3.5 3 3.5z" />
          </svg>
        </div>
        <div>
          <p class="text-[0.65rem] font-semibold tracking-[0.2em] uppercase mb-0.5 opacity-40" style="color: var(--t-text-light); font-family: var(--t-body-font);">Reservations</p>
          <p class="text-sm font-medium opacity-90 group-hover:opacity-100 transition-opacity" style="color: var(--t-text-light); font-family: var(--t-body-font);">{restaurant.phone}</p>
          <p class="text-xs opacity-50" style="color: var(--t-text-light); font-family: var(--t-body-font);">or reserve online below</p>
        </div>
      </a>
    </div>
  </div>
</section>
