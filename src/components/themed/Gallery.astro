---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;
const { gallery } = restaurant;

function baseFor(url: string) {
  return url.replace(/-(\d+)\.(jpg|jpeg|png|webp)$/i, '');
}
---

<section id="gallery" class="section-padding" style="background-color: var(--t-surface);" aria-labelledby="t-gallery-heading">
  <div class="container-wide">
    <div class="text-center mb-14">
      <p class="t-label mb-4">A Taste of</p>
      <h2 id="t-gallery-heading" class="t-title">{restaurant.name}</h2>
      <div class="flex justify-center mt-5"><div class="t-divider"></div></div>
    </div>

    <!-- Uniform aspect-ratio grid: 1 / 2 / 3 / 4 columns responsive -->
    <div class="t-gallery-grid">
      {gallery.map((item, i) => {
        const base = baseFor(item.url);
        const eager = i < 3;
        return (
          <button
            class="t-gallery-item group block overflow-hidden focus-visible:outline-none focus-visible:ring-2"
            style="background-color: var(--t-border);"
            aria-label={`View photo: ${item.alt}`}
            data-index={i}
            data-base={base}
            data-alt={item.alt}
          >
            <picture>
              <source
                type="image/webp"
                srcset={`${base}-400.webp 400w, ${base}-800.webp 800w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1280px) 33vw, 25vw"
              />
              <img
                src={`${base}-800.jpg`}
                srcset={`${base}-400.jpg 400w, ${base}-800.jpg 800w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1280px) 33vw, 25vw"
                alt={item.alt}
                class="t-gallery-img"
                loading={eager ? 'eager' : 'lazy'}
                decoding="async"
                width="800"
                height="600"
              />
            </picture>
            <div class="t-gallery-overlay" aria-hidden="true">
              <p class="text-white text-xs leading-snug line-clamp-2 drop-shadow">{item.alt}</p>
            </div>
          </button>
        );
      })}
    </div>

    <!-- Lightbox -->
    <div id="t-lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center" style="background-color: rgba(0,0,0,0.93);"
      role="dialog" aria-modal="true" aria-label="Photo lightbox"
    >
      <button id="t-lb-close" class="absolute top-5 right-5 text-white/60 hover:text-white transition-colors" aria-label="Close">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <button id="t-lb-prev" class="absolute left-4 text-white/60 hover:text-white p-2" aria-label="Previous">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="max-w-4xl max-h-[85vh] mx-16 flex flex-col items-center gap-4">
        <img id="t-lb-img" src="" alt="" class="max-w-full max-h-[75vh] object-contain" />
        <p id="t-lb-cap" class="text-white/60 text-sm text-center"></p>
      </div>
      <button id="t-lb-next" class="absolute right-4 text-white/60 hover:text-white p-2" aria-label="Next">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .t-gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 640px) { .t-gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 0.875rem; } }
  @media (min-width: 1024px) { .t-gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; } }
  @media (min-width: 1280px) { .t-gallery-grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; } }

  .t-gallery-item {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    cursor: pointer;
    border: 0;
    padding: 0;
  }
  .t-gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .t-gallery-item:hover .t-gallery-img { transform: scale(1.04); }

  .t-gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    background-color: rgba(0,0,0,0.22);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .t-gallery-item:hover .t-gallery-overlay,
  .t-gallery-item:focus-visible .t-gallery-overlay { opacity: 1; }
</style>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.t-gallery-item');
  const lb = document.getElementById('t-lightbox')!;
  const lbImg = document.getElementById('t-lb-img') as HTMLImageElement;
  const lbCap = document.getElementById('t-lb-cap')!;

  const photos = Array.from(items).map(el => ({ base: el.dataset.base!, alt: el.dataset.alt! }));
  let cur = 0;

  function open(i: number) {
    cur = (i + photos.length) % photos.length;
    lbImg.src = `${photos[cur].base}-1600.jpg`;
    lbImg.alt = photos[cur].alt;
    lbCap.textContent = photos[cur].alt;
    lb.classList.remove('hidden'); lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.add('hidden'); lb.classList.remove('flex');
    document.body.style.overflow = '';
  }

  items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
  document.getElementById('t-lb-close')!.addEventListener('click', close);
  document.getElementById('t-lb-prev')!.addEventListener('click', () => open(cur - 1));
  document.getElementById('t-lb-next')!.addEventListener('click', () => open(cur + 1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (lb.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') open(cur - 1);
    if (e.key === 'ArrowRight') open(cur + 1);
  });
</script>
