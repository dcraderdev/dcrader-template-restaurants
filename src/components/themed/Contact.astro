---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;
---

<section id="contact" class="section-padding" style="background-color: var(--t-surface);" aria-labelledby="t-contact-heading">
  <div class="container-wide">
    <div class="text-center mb-14 sr">
      <p class="t-label mb-4">Find Us</p>
      <h2 id="t-contact-heading" class="t-title">Visit {restaurant.name}</h2>
      <div class="flex justify-center mt-5"><div class="t-divider"></div></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 shadow-sm overflow-hidden sr sr-delay-1">
      <!-- Map -->
      <div class="lg:col-span-3 h-80 lg:h-full min-h-[320px]">
        <iframe
          title={`Map — ${restaurant.name}`}
          src={restaurant.mapEmbedUrl}
          class="w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

      <!-- Info panel -->
      <div class="lg:col-span-2 p-8 sm:p-10 lg:p-12 flex flex-col gap-8" style="background-color: var(--t-bg);">

        <!-- Address -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--t-text-muted); font-family: var(--t-body-font);">Address</p>
          <address class="not-italic">
            <p class="text-lg" style="font-family: var(--t-heading-font); color: var(--t-text);">{restaurant.address.street}</p>
            <p class="text-lg" style="font-family: var(--t-heading-font); color: var(--t-text);">{restaurant.address.city}, {restaurant.address.state} {restaurant.address.zip}</p>
          </address>
          <a href={restaurant.mapDirectionsUrl} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 mt-3 text-xs font-semibold tracking-[0.15em] uppercase transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2"
            style="color: var(--t-accent); font-family: var(--t-body-font);"
          >
            Get Directions
            <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>

        <!-- Hours -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--t-text-muted); font-family: var(--t-body-font);">Hours</p>
          <ul class="space-y-1.5">
            {restaurant.hours.map(h => {
              const isToday = h.day === ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][new Date().getDay()];
              return (
                <li class="flex justify-between gap-4 text-sm" style={`font-family: var(--t-body-font); color: ${isToday ? 'var(--t-text)' : 'var(--t-text-muted)'}; font-weight: ${isToday ? '600' : '400'};`}>
                  <span class="flex items-center gap-2">
                    {isToday && <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: var(--t-accent);" aria-label="Today" role="img"></span>}
                    <span>{h.day}</span>
                  </span>
                  <span>{h.open ? `${h.open} – ${h.close}` : 'Closed'}</span>
                </li>
              );
            })}
          </ul>
        </div>

        <!-- Phone & email -->
        <div class="space-y-3">
          <a href={`tel:${restaurant.phone.replace(/\D/g, '')}`}
            class="flex items-center gap-3 text-sm transition-colors duration-200 focus-visible:outline-none"
            style="color: var(--t-text-muted); font-family: var(--t-body-font);"
          >
            <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: var(--t-surface);">
              <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--t-accent);"><path d="M2 2.5C2 2.5 4 1 5.5 2.5S5 5.5 6.5 7s2.5-.5 4 1-1 3.5-1 3.5-3.5 1.5-6.5-1.5S2 2.5 2 2.5z"/></svg>
            </span>
            {restaurant.phone}
          </a>
          <a href={`mailto:${restaurant.email}`}
            class="flex items-center gap-3 text-sm transition-colors duration-200 focus-visible:outline-none"
            style="color: var(--t-text-muted); font-family: var(--t-body-font);"
          >
            <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: var(--t-surface);">
              <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--t-accent);"><rect x="1" y="3" width="14" height="10" rx="1.5"/><path d="M1 4l7 5 7-5"/></svg>
            </span>
            {restaurant.email}
          </a>
        </div>

        <!-- Social -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--t-text-muted); font-family: var(--t-body-font);">Follow</p>
          <div class="flex gap-3">
            {[
              { href: restaurant.social.instagram, label: 'Instagram', icon: 'M2 2h20v20H2zM16 12a4 4 0 11-8 0 4 4 0 018 0zM17.5 6.5h.01' },
              { href: restaurant.social.facebook, label: 'Facebook', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
            ].map(({ href, label, icon }) => (
              <a href={href} target="_blank" rel="noopener noreferrer"
                class="w-9 h-9 rounded-full border flex items-center justify-center transition-all duration-200 focus-visible:outline-none focus-visible:ring-2"
                style="border-color: var(--t-border-strong); color: var(--t-text-muted);"
                aria-label={label}
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={icon} />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
