---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props {
  restaurant: RestaurantConfig;
  /** Start nav in scrolled/solid state — use for light-background heroes (V2) */
  initialDark?: boolean;
}
const { restaurant, initialDark = false } = Astro.props;
---

<header>
  <nav id="t-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" aria-label="Main navigation"
    data-initial-dark={initialDark ? 'true' : 'false'}>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between h-[4.5rem] lg:h-20">

        <a id="t-nav-logo" href="#hero"
          class="text-xl tracking-wide text-white transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          style="font-family: var(--t-heading-font);"
          aria-label={`${restaurant.name} — back to top`}
        >
          {restaurant.name}
        </a>

        <div class="hidden md:flex items-center gap-6 lg:gap-8">
          {[
            { href: '#menu', label: 'Menu' },
            { href: '#about', label: 'Our Story' },
            { href: '#gallery', label: 'Gallery' },
            { href: '#contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <a href={href} class="t-nav-link text-xs font-medium tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
              style="font-family: var(--t-body-font);"
            >
              {label}
            </a>
          ))}
          <a href="#reservations"
            class="ml-2 px-5 py-2.5 text-xs font-semibold tracking-[0.2em] uppercase transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
            id="t-nav-cta"
            style="background-color: var(--t-accent); color: var(--t-text-light); font-family: var(--t-body-font);"
          >
            Reserve
          </a>
        </div>

        <button id="t-nav-toggle"
          class="md:hidden p-2 text-white transition-colors duration-200"
          aria-label="Open menu" aria-expanded="false" aria-controls="t-mobile-menu"
        >
          <svg id="t-icon-menu" class="w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <path d="M2 5h16M2 10h16M2 15h16" />
          </svg>
          <svg id="t-icon-close" class="w-5 h-5 hidden" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <path d="M4 4l12 12M16 4L4 16" />
          </svg>
        </button>
      </div>
    </div>

    <div id="t-mobile-menu" class="hidden md:hidden border-t shadow-lg" style="background-color: var(--t-bg); border-color: var(--t-border);">
      <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col gap-5">
        {[
          { href: '#menu', label: 'Menu' },
          { href: '#about', label: 'Our Story' },
          { href: '#gallery', label: 'Gallery' },
          { href: '#contact', label: 'Contact' },
        ].map(({ href, label }) => (
          <a href={href} class="t-mobile-link text-sm font-medium tracking-[0.2em] uppercase transition-colors duration-200"
            style="color: var(--t-text); font-family: var(--t-body-font);"
          >
            {label}
          </a>
        ))}
        <a href="#reservations" class="t-mobile-link mt-2 px-6 py-3.5 text-sm font-semibold tracking-[0.2em] uppercase text-center transition-colors duration-200"
          style="background-color: var(--t-accent); color: var(--t-text-light); font-family: var(--t-body-font);"
        >
          Reserve a Table
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('t-nav')!;
  const logo = document.getElementById('t-nav-logo')!;
  const links = nav.querySelectorAll<HTMLElement>('.t-nav-link');
  const toggle = document.getElementById('t-nav-toggle')!;
  const mobile = document.getElementById('t-mobile-menu')!;
  const iconMenu = document.getElementById('t-icon-menu')!;
  const iconClose = document.getElementById('t-icon-close')!;

  const bg = getComputedStyle(document.body).getPropertyValue('--t-bg').trim();
  const text = getComputedStyle(document.body).getPropertyValue('--t-text').trim();
  const initialDark = nav.dataset.initialDark === 'true';

  let scrolled = initialDark;

  function setScrolled(v: boolean) {
    if (v === scrolled && !initialDark) return;
    scrolled = v;
    if (v) {
      nav.style.backgroundColor = bg;
      nav.style.borderBottom = `1px solid var(--t-border)`;
      nav.style.boxShadow = '0 1px 8px rgba(0,0,0,0.06)';
      logo.style.color = text;
      links.forEach(l => { l.style.color = text; l.style.opacity = '0.8'; });
      toggle.style.color = text;
    } else {
      nav.style.backgroundColor = '';
      nav.style.borderBottom = '';
      nav.style.boxShadow = '';
      logo.style.color = 'white';
      links.forEach(l => { l.style.color = 'rgba(255,255,255,0.9)'; l.style.opacity = ''; });
      toggle.style.color = 'white';
    }
  }

  // Apply initial state immediately (no scroll event needed)
  if (initialDark) setScrolled(true);

  window.addEventListener('scroll', () => setScrolled(window.scrollY > 60), { passive: true });

  toggle.addEventListener('click', () => {
    const open = !mobile.classList.contains('hidden');
    mobile.classList.toggle('hidden');
    iconMenu.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
    if (!open) setScrolled(true);
  });

  mobile.querySelectorAll('.t-mobile-link').forEach(l => {
    l.addEventListener('click', () => {
      mobile.classList.add('hidden');
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      setScrolled(window.scrollY > 60);
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const href = a.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      const top = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - 72;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  });
</script>
