---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;
const { about } = restaurant;
const paragraphs = about.story.split('\n\n');
const ambianceBase = about.ambiance.replace(/-(\d+)\.(jpg|jpeg|png|webp)$/i, '');
const chefBase = about.chef.photo.replace(/-(\d+)\.(jpg|jpeg|png|webp)$/i, '');
---

<section id="about" class="section-padding overflow-hidden" style="background-color: var(--t-bg);" aria-labelledby="t-about-heading">
  <div class="container-wide">

    <!-- Story + image -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center mb-20 sr">
      <div>
        <p class="t-label mb-4">Our Story</p>
        <h2 id="t-about-heading" class="t-title mb-6">{about.headline}</h2>
        <div class="t-divider mb-8"></div>
        <div class="space-y-5">
          {paragraphs.map(p => (
            <p class="text-[1.0625rem] leading-relaxed" style="color: var(--t-text-muted); font-family: var(--t-body-font);">{p}</p>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -top-5 -right-5 w-full h-full border-2 hidden lg:block" style="border-color: var(--t-gold); opacity: 0.3;" aria-hidden="true"></div>
        <picture>
          <source type="image/webp" srcset={`${ambianceBase}-400.webp 400w, ${ambianceBase}-800.webp 800w`} sizes="(max-width: 1024px) 100vw, 50vw" />
          <img
            src={`${ambianceBase}-800.jpg`}
            srcset={`${ambianceBase}-400.jpg 400w, ${ambianceBase}-800.jpg 800w`}
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt={about.ambianceAlt}
            class="relative w-full object-cover aspect-[4/3] lg:aspect-[3/4]"
            loading="lazy" decoding="async"
          />
        </picture>
      </div>
    </div>

    <!-- Chef block -->
    <div class="flex flex-col sm:flex-row items-start gap-8 lg:gap-12 p-8 sm:p-12 lg:p-16 sr sr-delay-1"
      style="background-color: var(--t-dark);"
    >
      <div class="flex-shrink-0">
        <div class="relative w-28 h-28 sm:w-36 sm:h-36">
          <picture>
            <source type="image/webp" srcset={`${chefBase}-400.webp`} />
            <img
              src={`${chefBase}-400.jpg`}
              alt={about.chef.photoAlt}
              class="w-full h-full object-cover object-top rounded-full"
              style="border: 2px solid var(--t-gold); opacity: 0.9;"
              loading="lazy" decoding="async"
            />
          </picture>
        </div>
      </div>
      <div>
        <p class="text-xs font-semibold tracking-[0.25em] uppercase mb-3" style="color: var(--t-gold); font-family: var(--t-body-font);">Meet the Chef</p>
        <h3 class="text-2xl sm:text-3xl mb-1" style="font-family: var(--t-heading-font); color: var(--t-text-light);">{about.chef.name}</h3>
        <p class="text-sm mb-5" style="color: var(--t-text-muted); font-family: var(--t-body-font);">{about.chef.title}</p>
        <p class="text-base leading-relaxed max-w-xl" style="color: rgba(255,255,255,0.65); font-family: var(--t-body-font);">{about.chef.bio}</p>
      </div>
    </div>
  </div>
</section>
