---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;
const lines = restaurant.heroHeadline.split('\n');
---

<section id="hero" aria-label="Hero" style="display: flex; flex-direction: column; min-height: 100vh;">

  <!-- Image panel: top on mobile, right side on desktop -->
  <div style="position: relative; overflow: hidden; min-height: 55vw; flex: 1 1 auto; order: 1;">
    <img
      src={restaurant.hero.image}
      srcset={`${restaurant.hero.imageMobile} 800w, ${restaurant.hero.image} 1920w`}
      sizes="(max-width: 1024px) 100vw, 50vw"
      alt={restaurant.hero.imageAlt}
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block;"
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Text panel: below image on mobile, left side on desktop -->
  <div style="order: 2; display: flex; flex-direction: column; justify-content: center; background-color: var(--t-bg); padding: 5rem 2.5rem 5rem; flex: 1 1 auto;">
    <p style="font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: var(--t-label-tracking); color: var(--t-text-muted); font-family: var(--t-body-font); margin: 0 0 2.5rem;">{restaurant.tagline}</p>
    <h1 style="font-family: var(--t-heading-font); color: var(--t-text); line-height: 0.9; margin: 0 0 2.5rem;">
      {lines.map(line => (
        <span style="display: block; font-size: clamp(3rem, 8vw, 7rem);">{line}</span>
      ))}
    </h1>
    <div style="width: 2.5rem; height: 1px; background-color: var(--t-text); opacity: 0.18; margin: 0 0 2.5rem;" aria-hidden="true"></div>
    <p style="font-size: 1rem; line-height: 1.7; color: var(--t-text-muted); font-family: var(--t-body-font); max-width: 22rem; margin: 0 0 3rem;">{restaurant.heroSubtitle}</p>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href="#reservations" class="t-btn-primary">Reserve</a>
      <a href="#menu" class="t-btn-outline">Menu</a>
    </div>
    <p style="margin-top: 4rem; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--t-text-muted); font-family: var(--t-body-font); opacity: 0.45;">{restaurant.address.city}, {restaurant.address.state}</p>
  </div>

</section>

<style>
  @media (min-width: 1024px) {
    #hero {
      flex-direction: row;
    }
    #hero > div:first-child {
      order: 2;
      flex: 0 0 50%;
      min-height: 100vh;
      max-width: 50%;
    }
    #hero > div:last-child {
      order: 1;
      flex: 0 0 50%;
      max-width: 50%;
      padding: 0 5rem 0 clamp(2rem, 6vw, 6rem);
    }
  }
</style>
