---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;
const lines = restaurant.heroHeadline.split('\n');
---

<section id="hero" class="relative min-h-screen flex flex-col justify-end overflow-hidden" aria-label="Hero">
  <img
    src={restaurant.hero.image}
    srcset={`${restaurant.hero.imageMobile} 800w, ${restaurant.hero.image} 1920w`}
    sizes="100vw"
    alt={restaurant.hero.imageAlt}
    class="absolute inset-0 w-full h-full object-cover object-center"
    fetchpriority="high" loading="eager" decoding="async"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/92 via-black/45 to-black/15" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/35 via-transparent to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full px-6 lg:px-8 pb-24 lg:pb-36">
    <div class="max-w-3xl" id="v1-hero-content">
      <p class="text-[0.68rem] font-semibold tracking-[0.42em] uppercase mb-8 hero-line" style="color: var(--t-gold); font-family: var(--t-body-font); opacity:0; transform:translateY(12px); transition: opacity 0.6s ease 0.3s, transform 0.6s ease 0.3s;">{restaurant.tagline}</p>
      <h1 class="leading-[0.93] mb-3" style="font-family: var(--t-heading-font);">
        {lines.map((line, i) => (
          <span class={`block text-[3.5rem] sm:text-[5rem] lg:text-[7.25rem] xl:text-[8.75rem]${i > 0 ? ' italic' : ''} hero-line`} style={`color: white; opacity:0; transform:translateY(16px); transition: opacity 0.75s ease ${0.42 + i * 0.12}s, transform 0.75s ease ${0.42 + i * 0.12}s;`}>{line}</span>
        ))}
      </h1>
      <div class="flex items-center gap-4 my-9 hero-line" aria-hidden="true" style="opacity:0; transform:translateY(10px); transition: opacity 0.6s ease 0.72s, transform 0.6s ease 0.72s;">
        <div class="w-16 h-px" style="background-color: var(--t-gold); opacity: 0.55;"></div>
        <div class="w-1.5 h-1.5 rounded-full" style="background-color: var(--t-gold); opacity: 0.55;"></div>
        <div class="w-16 h-px" style="background-color: var(--t-gold); opacity: 0.55;"></div>
      </div>
      <p class="text-lg sm:text-xl font-light max-w-md leading-relaxed mb-12 hero-line" style="color: rgba(255,255,255,0.68); font-family: var(--t-body-font); opacity:0; transform:translateY(10px); transition: opacity 0.6s ease 0.84s, transform 0.6s ease 0.84s;">{restaurant.heroSubtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 hero-line" style="opacity:0; transform:translateY(10px); transition: opacity 0.6s ease 0.96s, transform 0.6s ease 0.96s;">
        <a href="#reservations" class="t-btn-primary">Reserve a Table</a>
        <a href="#menu" class="t-btn-ghost-white">View Menu</a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden lg:flex flex-col items-center gap-2 select-none" style="color: rgba(255,255,255,0.38);" aria-hidden="true">
    <span class="text-[0.6rem] tracking-[0.3em] uppercase" style="font-family: var(--t-body-font);">Discover</span>
    <svg class="w-5 h-5 animate-float" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10 4v12M4 12l6 6 6-6"/></svg>
  </div>
</section>
