---
import type { RestaurantConfig } from '../../data/restaurants/types';
interface Props { restaurant: RestaurantConfig; }
const { restaurant } = Astro.props;
const lines = restaurant.heroHeadline.split('\n');
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden" aria-label="Hero">
  <img
    src={restaurant.hero.image}
    srcset={`${restaurant.hero.imageMobile} 800w, ${restaurant.hero.image} 1920w`}
    sizes="100vw"
    alt={restaurant.hero.imageAlt}
    class="absolute inset-0 w-full h-full object-cover object-center"
    fetchpriority="high" loading="eager" decoding="async"
  />
  <!-- Near-black overlay — dramatic moody steakhouse, steak visible through right side -->
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(11,10,8,0.93) 0%, rgba(11,10,8,0.72) 50%, rgba(11,10,8,0.35) 100%);" aria-hidden="true"></div>
  <!-- Vignette bottom -->
  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(11,10,8,0.55) 0%, transparent 40%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full px-8 lg:px-16 py-24">
    <div class="max-w-2xl" id="v5-hero-content">
      <!-- Gold eyebrow rule -->
      <div class="flex items-center gap-4 mb-10 hero-line" aria-hidden="true" style="opacity:0; transform:translateY(12px); transition: opacity 0.6s ease 0.2s, transform 0.6s ease 0.2s;">
        <div class="w-16 h-px" style="background-color: var(--t-gold);"></div>
        <p class="text-[0.65rem] tracking-[0.45em] uppercase" style="color: var(--t-gold); font-family: var(--t-body-font);">{restaurant.city}</p>
      </div>
      <h1 class="leading-[0.92] mb-10" style="font-family: var(--t-heading-font);">
        {lines.map((line, i) => (
          <span class={`block text-[3.5rem] sm:text-[5rem] lg:text-[6.5rem] xl:text-[7.5rem]${i > 0 ? ' italic' : ''} hero-line`} style={`color: var(--t-text-light); opacity:0; transform:translateY(18px); transition: opacity 0.8s ease ${0.32 + i * 0.14}s, transform 0.8s ease ${0.32 + i * 0.14}s;`}>{line}</span>
        ))}
      </h1>
      <!-- Gold ornament -->
      <div class="flex items-center gap-3 mb-10 hero-line" aria-hidden="true" style="opacity:0; transform:translateY(10px); transition: opacity 0.6s ease 0.68s, transform 0.6s ease 0.68s;">
        <div class="w-8 h-px" style="background-color: var(--t-gold);"></div>
        <div class="w-1.5 h-1.5 rounded-full" style="background-color: var(--t-gold);"></div>
        <div class="w-8 h-px" style="background-color: var(--t-gold);"></div>
      </div>
      <p class="text-lg leading-relaxed mb-12 max-w-sm hero-line" style={`color: rgba(237,232,222,0.62); font-family: var(--t-body-font); opacity:0; transform:translateY(10px); transition: opacity 0.6s ease 0.8s, transform 0.6s ease 0.8s;`}>{restaurant.heroSubtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 hero-line" style="opacity:0; transform:translateY(10px); transition: opacity 0.6s ease 0.92s, transform 0.6s ease 0.92s;">
        <a href="#reservations" class="t-btn-primary">Reserve Your Table</a>
        <a href="#menu" class="t-btn-ghost-white">View Menu</a>
      </div>
      <p class="mt-14 text-[0.62rem] tracking-[0.4em] uppercase hero-line" style="color: var(--t-gold); opacity:0; font-family: var(--t-body-font); transition: opacity 0.6s ease 1.05s;">{restaurant.tagline}</p>
    </div>
  </div>
</section>
