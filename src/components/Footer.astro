---
import { restaurant } from '../data/restaurant';

const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-white" aria-label="Footer">

  <!-- Top section -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <h2 class="font-serif text-3xl text-white mb-2">{restaurant.name}</h2>
        <p class="font-sans text-xs text-white/40 tracking-[0.2em] uppercase mb-6">
          {restaurant.tagline}
        </p>
        <p class="font-sans text-sm text-white/55 leading-relaxed max-w-xs">
          Coastal Italian dining on La Jolla's Prospect Street. Open Tuesday through Sunday.
        </p>

        <!-- Social icons -->
        <div class="flex gap-3 mt-6" aria-label="Social media links">
          <a
            href={restaurant.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white/40 hover:text-white hover:border-white/60 transition-all duration-200 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white"
            aria-label="Instagram"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a
            href={restaurant.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white/40 hover:text-white hover:border-white/60 transition-all duration-200 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white"
            aria-label="Facebook"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
            </svg>
          </a>
          <a
            href={restaurant.social.yelp}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white/40 hover:text-white hover:border-white/60 transition-all duration-200 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white"
            aria-label="Yelp"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.87 14.2l-4.64-1.16a.76.76 0 00-.9.9l1.2 4.64c.15.6.9.78 1.35.36l3.46-3.46c.45-.42.12-1.14-.47-1.28zm-7.57 2.6l-1.5 4.45c-.2.6.3 1.18.93 1.08l4.73-.75c.63-.1.87-.88.44-1.35l-3.25-3.7a.76.76 0 00-1.35.27zM10.1 3.44l-.75 4.73c-.1.63.45 1.13 1.08.93l4.45-1.5a.76.76 0 00.27-1.35L11.45 3a.76.76 0 00-1.35.44zm-2 8.27L3.14 9.3c-.47-.47-1.25-.23-1.35.44l-.75 4.73c-.1.63.45 1.13 1.08.93l4.63-1.5a.76.76 0 00.36-1.2zM3.13 5.4L6.6 8.87c.45.45 1.2.27 1.35-.44l.75-4.73c.1-.63-.45-1.13-1.08-.93L3.9 4.02c-.63.2-.87.98-.77 1.38z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <nav aria-label="Footer navigation">
        <h3 class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-white/40 mb-5">
          Explore
        </h3>
        <ul class="space-y-3">
          {[
            { href: '#menu', label: 'Menu' },
            { href: '#about', label: 'Our Story' },
            { href: '#gallery', label: 'Gallery' },
            { href: '#reservations', label: 'Reservations' },
            { href: '#contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="font-sans text-sm text-white/55 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Hours -->
      <div>
        <h3 class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-white/40 mb-5">
          Hours
        </h3>
        <ul class="space-y-2">
          {restaurant.hours.map(h => (
            <li class="flex justify-between gap-4 font-sans text-sm">
              <span class="text-white/55">{h.day.slice(0, 3)}</span>
              <span class="text-white/75">
                {h.open ? `${h.open.replace(':00', '').replace(' PM', '')}–${h.close!.replace(':00', '')}` : 'Closed'}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + reserve -->
      <div>
        <h3 class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-white/40 mb-5">
          Contact
        </h3>
        <address class="not-italic space-y-3 mb-6">
          <p class="font-sans text-sm text-white/55 leading-relaxed">
            {restaurant.address.street}<br />
            {restaurant.address.city}, {restaurant.address.state} {restaurant.address.zip}
          </p>
          <a href={`tel:${restaurant.phone.replace(/\D/g, '')}`} class="block font-sans text-sm text-white/55 hover:text-white transition-colors duration-200">
            {restaurant.phone}
          </a>
          <a href={`mailto:${restaurant.email}`} class="block font-sans text-sm text-white/55 hover:text-white transition-colors duration-200">
            {restaurant.email}
          </a>
        </address>
        <a href="#reservations" class="btn-primary text-xs py-3 px-5 inline-flex">
          Reserve a Table
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-sans text-xs text-white/30">
        &copy; {year} {restaurant.name}. All rights reserved.
      </p>
      <p class="font-sans text-xs text-white/20">
        Photos: <a href="https://unsplash.com" target="_blank" rel="noopener noreferrer" class="hover:text-white/40 transition-colors duration-200">Unsplash</a>
        (free commercial license)
      </p>
    </div>
  </div>

</footer>
