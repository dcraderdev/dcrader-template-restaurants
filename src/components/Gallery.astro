---
import { restaurant } from '../data/restaurant';
const { gallery } = restaurant;

function baseFor(url: string) {
  return url.replace(/-(\d+)\.(jpg|jpeg|png|webp)$/i, '');
}
---

<section id="gallery" class="section-padding bg-wheat/40" aria-labelledby="gallery-heading">
  <div class="container-wide">

    <div class="text-center mb-14">
      <p class="section-label mb-4">A Taste of</p>
      <h2 id="gallery-heading" class="section-title">{restaurant.name}</h2>
      <div class="flex justify-center mt-5">
        <div class="divider-gold"></div>
      </div>
    </div>

    <div class="legacy-gallery-grid">
      {gallery.map((item, i) => {
        const base = baseFor(item.url);
        const eager = i < 3;
        return (
          <button
            class="legacy-gallery-item group block overflow-hidden bg-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            aria-label={`View photo: ${item.alt}`}
            data-index={i}
            data-base={base}
            data-alt={item.alt}
          >
            <picture>
              <source
                type="image/webp"
                srcset={`${base}-400.webp 400w, ${base}-800.webp 800w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1280px) 33vw, 25vw"
              />
              <img
                src={`${base}-800.jpg`}
                srcset={`${base}-400.jpg 400w, ${base}-800.jpg 800w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1280px) 33vw, 25vw"
                alt={item.alt}
                class="legacy-gallery-img"
                loading={eager ? 'eager' : 'lazy'}
                decoding="async"
                width="800"
                height="600"
              />
            </picture>
            <div class="legacy-gallery-overlay" aria-hidden="true">
              <p class="font-sans text-white text-xs leading-snug line-clamp-2 drop-shadow">{item.alt}</p>
            </div>
          </button>
        );
      })}
    </div>

    <div
      id="lightbox"
      class="fixed inset-0 z-[100] hidden items-center justify-center bg-charcoal/95 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-label="Photo lightbox"
    >
      <button
        id="lightbox-close"
        class="absolute top-5 right-5 text-white/60 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
        aria-label="Close lightbox"
      >
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>

      <button id="lightbox-prev" class="absolute left-4 text-white/60 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white p-2" aria-label="Previous photo">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </button>

      <div class="max-w-4xl max-h-[85vh] mx-16 flex flex-col items-center gap-4">
        <img
          id="lightbox-img"
          src=""
          alt=""
          class="max-w-full max-h-[75vh] object-contain"
        />
        <p id="lightbox-caption" class="font-sans text-white/60 text-sm text-center"></p>
      </div>

      <button id="lightbox-next" class="absolute right-4 text-white/60 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white p-2" aria-label="Next photo">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6" />
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .legacy-gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 640px) { .legacy-gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 0.875rem; } }
  @media (min-width: 1024px) { .legacy-gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; } }
  @media (min-width: 1280px) { .legacy-gallery-grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; } }

  .legacy-gallery-item {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    cursor: pointer;
    border: 0;
    padding: 0;
  }
  .legacy-gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .legacy-gallery-item:hover .legacy-gallery-img { transform: scale(1.04); }

  .legacy-gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    background-color: rgba(0,0,0,0.22);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .legacy-gallery-item:hover .legacy-gallery-overlay,
  .legacy-gallery-item:focus-visible .legacy-gallery-overlay { opacity: 1; }
</style>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.legacy-gallery-item');
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption')!;
  const lbClose = document.getElementById('lightbox-close')!;
  const lbPrev = document.getElementById('lightbox-prev')!;
  const lbNext = document.getElementById('lightbox-next')!;

  let current = 0;
  const photos = Array.from(items).map(el => ({
    base: el.dataset.base!,
    alt: el.dataset.alt!,
  }));

  function open(i: number) {
    current = (i + photos.length) % photos.length;
    lbImg.src = `${photos[current].base}-1600.jpg`;
    lbImg.alt = photos[current].alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    lbCaption.textContent = photos[current].alt;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function close() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', () => open(current - 1));
  lbNext.addEventListener('click', () => open(current + 1));

  lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });

  document.addEventListener('keydown', e => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') open(current - 1);
    if (e.key === 'ArrowRight') open(current + 1);
  });
</script>
