---
import '../global.css';
import { getImage } from 'astro:assets';
import type { RestaurantConfig } from '../data/restaurants/types';

interface Props {
  restaurant: RestaurantConfig;
  /** data-theme attribute for CSS variable theming: v1|v2|v3|v4|v5 */
  theme?: string;
  /** Google Fonts URL for this template variant */
  fontUrl?: string;
  /** Override page title */
  title?: string;
}

const {
  restaurant,
  theme = 'v1',
  fontUrl = 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap',
  title = restaurant.seo.title,
} = Astro.props;

const { description, ogImage, canonicalUrl } = restaurant.seo;

// Resolve ImageMetadata to a final hashed URL for OG / JSON-LD / preload
const ogProcessed = await getImage({ src: ogImage, width: 1200, format: 'jpg' });
const ogImageUrl = new URL(ogProcessed.src, Astro.site ?? canonicalUrl).toString();

// Hero preload (above-the-fold). Build a multi-format srcset using getImage.
const heroAvif = await getImage({ src: restaurant.hero.image, format: 'avif', widths: [640, 1024, 1920], sizes: '100vw' });
const heroWebp = await getImage({ src: restaurant.hero.image, format: 'webp', widths: [640, 1024, 1920], sizes: '100vw' });
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FDFAF4" />

    <!-- Open Graph -->
    <meta property="og:type" content="restaurant.restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Hero image preload (above-the-fold, multi-format) -->
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href={heroAvif.src}
      imagesrcset={heroAvif.srcSet.attribute}
      imagesizes="100vw"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/webp"
      href={heroWebp.src}
      imagesrcset={heroWebp.srcSet.attribute}
      imagesizes="100vw"
      fetchpriority="high"
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontUrl} rel="stylesheet" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Restaurant',
      name: restaurant.name,
      description,
      url: canonicalUrl,
      telephone: restaurant.phone,
      email: restaurant.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: restaurant.address.street,
        addressLocality: restaurant.address.city,
        addressRegion: restaurant.address.state,
        postalCode: restaurant.address.zip,
        addressCountry: 'US',
      },
      servesCuisine: restaurant.cuisine,
      image: ogImageUrl,
      openingHours: restaurant.hours
        .filter(h => h.open !== null)
        .map(h => `${h.day.slice(0, 2)} ${h.open}–${h.close}`),
    })} />

    <title>{title}</title>
    <script src="/template-topheader.js" defer></script>
    <style>
      html { scroll-padding-top: 40px !important; }
      body { padding-top: 36px !important; }
      body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
    </style>
  </head>
  <body data-theme={theme} style="background-color: var(--t-bg); color: var(--t-text); font-family: var(--t-body-font);">
    <slot />
  </body>
</html>
